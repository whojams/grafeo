# GraphQL mutation support for Grafeo LPG
#
# Covers: createNode, updateNode, deleteNode mutations, end-to-end workflows
# combining mutations with verification queries, create without selection set,
# multi-property updates, and delete with count verification.
# Uses the social_network dataset as baseline, then mutates via GraphQL.

meta:
  language: graphql
  model: lpg
  title: GraphQL mutations
  dataset: social_network

tests:

  # ---------------------------------------------------------------------------
  # Create mutations
  # ---------------------------------------------------------------------------

  - name: create_person_with_name_and_age
    statements:
      - "mutation { createPerson(name: \"Django\", age: 28) { name } }"
      - "{ person { name } }"
    expect:
      count: 4

  - name: create_person_with_multiple_properties
    statements:
      - "mutation { createPerson(name: \"Jules\", age: 32, city: \"Barcelona\") { name } }"
      - "{ person(name: \"Jules\") { name age city } }"
    expect:
      rows:
        - [Jules, 32, Barcelona]

  - name: create_company_node
    statements:
      - "mutation { createCompany(name: \"Acme Corp\", founded: 2020) { name } }"
      - "{ company { name } }"
    expect:
      count: 2

  - name: create_movie_node
    # createMovie should produce a node with label "Movie"
    statements:
      - "mutation { createMovie(title: \"Pulp Fiction\", year: 1994) { title } }"
      - "{ movie { title year } }"
    expect:
      rows:
        - [Pulp Fiction, 1994]

  - name: create_label_capitalization
    # The mutation name determines the label: createMovie -> label "Movie"
    statements:
      - "mutation { createMovie(title: \"Kill Bill\", year: 2003) { title } }"
      - "{ movie(title: \"Kill Bill\") { title } }"
    expect:
      rows:
        - [Kill Bill]

  - name: create_then_verify_with_query
    statements:
      - "mutation { createPerson(name: \"Mia\", age: 29, city: \"Prague\") { name } }"
      - "{ person(name: \"Mia\") { name age city } }"
    expect:
      rows:
        - [Mia, 29, Prague]

  - name: create_person_increases_count
    statements:
      - "mutation { createPerson(name: \"Butch\", age: 40) { name } }"
      - "{ person { name } }"
    expect:
      count: 4

  # ---------------------------------------------------------------------------
  # Update mutations
  # ---------------------------------------------------------------------------

  - name: update_person_age_by_name
    statements:
      - "mutation { updatePerson(name: \"Alix\", age: 31) { name age } }"
      - "{ person(name: \"Alix\") { name age } }"
    expect:
      rows:
        - [Alix, 31]

  - name: update_person_city
    statements:
      - "mutation { updatePerson(name: \"Gus\", city: \"Prague\") { name } }"
      - "{ person(name: \"Gus\") { name city } }"
    expect:
      rows:
        - [Gus, Prague]

  - name: update_preserves_other_properties
    # Updating age should not erase city
    statements:
      - "mutation { updatePerson(name: \"Vincent\", age: 36) { name } }"
      - "{ person(name: \"Vincent\") { name age city } }"
    expect:
      rows:
        - [Vincent, 36, Paris]

  - name: update_without_selection_set
    # Mutation with no selection set should still succeed
    statements:
      - "mutation { updatePerson(name: \"Alix\", age: 33) }"
      - "{ person(name: \"Alix\") { name age } }"
    expect:
      rows:
        - [Alix, 33]

  - name: update_by_non_id_property
    # Filter by city instead of name
    statements:
      - "mutation { updatePerson(city: \"Berlin\", age: 26) { name } }"
      - "{ person(name: \"Gus\") { name age } }"
    expect:
      rows:
        - [Gus, 26]

  # ---------------------------------------------------------------------------
  # Delete mutations
  # ---------------------------------------------------------------------------

  - name: delete_person_by_name
    statements:
      - "mutation { deletePerson(name: \"Vincent\") { success } }"
      - "{ person { name } }"
    expect:
      count: 2

  - name: delete_company_by_name
    statements:
      - "mutation { deleteCompany(name: \"Grafeo OSS\") { success } }"
      - "{ company { name } }"
    expect:
      empty: true

  - name: delete_person_preserves_others
    # Deleting one person should leave the rest intact
    statements:
      - "mutation { deletePerson(name: \"Gus\") { success } }"
      - "{ person(name: \"Alix\") { name age } }"
    expect:
      rows:
        - [Alix, 30]

  - name: delete_then_count_remaining
    statements:
      - "mutation { deletePerson(name: \"Alix\") { success } }"
      - "{ person { name } }"
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # End-to-end workflows
  # ---------------------------------------------------------------------------

  - name: e2e_create_then_filter
    statements:
      - "mutation { createPerson(name: \"Shosanna\", age: 27, city: \"Paris\") { name } }"
      - "{ person(city: \"Paris\") { name } }"
    expect:
      rows:
        - [Vincent]
        - [Shosanna]

  - name: e2e_create_update_verify
    statements:
      - "mutation { createPerson(name: \"Hans\", age: 50, city: \"Berlin\") { name } }"
      - "mutation { updatePerson(name: \"Hans\", age: 51) { name } }"
      - "{ person(name: \"Hans\") { name age city } }"
    expect:
      rows:
        - [Hans, 51, Berlin]

  - name: e2e_create_two_delete_one_verify
    statements:
      - "mutation { createPerson(name: \"Beatrix\", age: 33, city: \"Amsterdam\") { name } }"
      - "mutation { createPerson(name: \"Django\", age: 28, city: \"Barcelona\") { name } }"
      - "mutation { deletePerson(name: \"Django\") { success } }"
      - "{ person(name: \"Beatrix\") { name age city } }"
    expect:
      rows:
        - [Beatrix, 33, Amsterdam]

  - name: e2e_create_then_count
    statements:
      - "mutation { createPerson(name: \"Jules\", age: 32) { name } }"
      - "mutation { createPerson(name: \"Mia\", age: 29) { name } }"
      - "{ person { name } }"
    expect:
      count: 5

  - name: e2e_create_then_query_with_ordering
    statements:
      - "mutation { createPerson(name: \"Butch\", age: 40, city: \"Prague\") { name } }"
      - "{ person(orderBy: { name: ASC }) { name } }"
    expect:
      rows:
        - [Alix]
        - [Butch]
        - [Gus]
        - [Vincent]

  # ---------------------------------------------------------------------------
  # Boolean and float property types
  # ---------------------------------------------------------------------------

  - name: create_with_boolean_property
    statements:
      - "mutation { createPerson(name: \"Beatrix\", active: true) { name } }"
      - "{ person(name: \"Beatrix\") { name active } }"
    expect:
      rows:
        - [Beatrix, true]

  - name: create_with_float_property
    statements:
      - "mutation { createPerson(name: \"Django\", score: 9.5) { name } }"
      - "{ person(name: \"Django\") { name score } }"
    expect:
      rows:
        - [Django, 9.5]

  # ---------------------------------------------------------------------------
  # Mutation return values
  # ---------------------------------------------------------------------------

  - name: create_returns_created_data
    query: "mutation { createPerson(name: \"Jules\", age: 32) { name age } }"
    expect:
      rows:
        - [Jules, 32]

  - name: update_returns_updated_data
    query: "mutation { updatePerson(name: \"Alix\", age: 31) { name age } }"
    expect:
      rows:
        - [Alix, 31]

  # ---------------------------------------------------------------------------
  # Delete edge cases
  # ---------------------------------------------------------------------------

  - name: delete_nonexistent_node_succeeds
    query: "mutation { deletePerson(name: \"NonExistent\") }"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # Create with no selection set
  # ---------------------------------------------------------------------------

  - name: create_without_selection_set
    statements:
      - "mutation { createPerson(name: \"Shosanna\", age: 27) }"
      - "{ person(name: \"Shosanna\") { name age } }"
    expect:
      rows:
        - [Shosanna, 27]

  # ---------------------------------------------------------------------------
  # Update multiple properties at once
  # ---------------------------------------------------------------------------

  - name: update_multiple_properties
    statements:
      - "mutation { updatePerson(name: \"Alix\", age: 31, city: \"Prague\") { name age city } }"
      - "{ person(name: \"Alix\") { name age city } }"
    expect:
      rows:
        - [Alix, 31, Prague]

  # ---------------------------------------------------------------------------
  # Delete then verify edge cleanup
  # ---------------------------------------------------------------------------

  - name: delete_person_then_verify_count
    statements:
      - "mutation { deletePerson(name: \"Alix\") }"
      - "{ person { name } }"
    expect:
      count: 2
