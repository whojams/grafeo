# GraphQL implementation gaps on RDF-like data
#
# Documents known RDF-specific limitations in the GraphQL translator.
# All tests are skipped with reason strings explaining the gap.

meta:
  language: graphql
  model: rdf
  section: gaps
  title: Known GraphQL gaps on RDF data
  dataset: rdf_social
  requires: [graphql]

tests:

  # ---------------------------------------------------------------------------
  # Variable substitution ($variable not wired)
  # ---------------------------------------------------------------------------

  - name: variable_substitution_string
    skip: "Variable substitution not yet wired in the GraphQL translator"
    query: |
      query GetPerson($personName: String!) {
        person(name: $personName) { name age }
      }
    variables:
      personName: "Alix"
    expect:
      rows:
        - [Alix, 30]

  - name: variable_substitution_int
    skip: "Variable substitution not yet wired in the GraphQL translator"
    query: |
      query GetByAge($minAge: Int!) {
        person(age_gte: $minAge) { name age }
      }
    variables:
      minAge: 30
    expect:
      count: 3

  # ---------------------------------------------------------------------------
  # Directive execution (@skip / @include)
  # ---------------------------------------------------------------------------

  - name: directive_skip_true
    skip: "Directives (@skip, @include) not evaluated during translation"
    query: "{ person { name age @skip(if: true) } }"
    expect:
      columns: [name]
      count: 5

  - name: directive_include_false
    skip: "Directives (@skip, @include) not evaluated during translation"
    query: "{ person { name age @include(if: false) } }"
    expect:
      columns: [name]
      count: 5

  - name: directive_include_true
    skip: "Directives (@skip, @include) not evaluated during translation"
    query: "{ person { name age @include(if: true) } }"
    expect:
      count: 5

  # ---------------------------------------------------------------------------
  # Multiple root fields (only first root field processed)
  # ---------------------------------------------------------------------------

  - name: multiple_root_fields
    skip: "Only the first root field is processed, subsequent root fields are ignored"
    query: |
      query {
        person { name }
        organization { name }
      }
    expect:
      # Should return rows for both Person and Organization types
      count: 6

  # ---------------------------------------------------------------------------
  # Aggregation (no count/sum/avg support)
  # ---------------------------------------------------------------------------

  - name: aggregation_count
    skip: "Aggregation functions not supported in GraphQL translator"
    query: "{ personCount: person { _count } }"
    expect:
      rows:
        - [5]

  - name: aggregation_avg_age
    skip: "Aggregation functions not supported in GraphQL translator"
    query: "{ person { _avg(field: age) } }"
    expect:
      rows:
        - [30]

  - name: aggregation_sum_age
    skip: "Aggregation functions not supported in GraphQL translator"
    query: "{ person { _sum(field: age) } }"
    expect:
      rows:
        - [150]
