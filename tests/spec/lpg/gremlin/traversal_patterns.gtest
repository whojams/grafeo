# Gremlin traversal patterns and pagination edge cases: skip(), hasId(),
#                       multi-hop chains, as()/select() complex patterns,
#                       traversal depth edge cases, range() edge cases,
#                       limit() edge cases
#
# Covers weakly-tested traversal patterns and pagination.
#
# Social network topology (from dataset):
#   Persons: Alix(30, Amsterdam), Gus(25, Berlin), Vincent(35, Paris)
#   Company: Grafeo OSS (founded 2025)
#   Edges: Alix-KNOWS{since:2020}->Gus, Gus-KNOWS{since:2021}->Vincent,
#          Alix-WORKS_AT{role:'Engineer',since:2019}->Grafeo OSS
#
# Traversal summary:
#   Alix  out(): Gus (KNOWS), Grafeo OSS (WORKS_AT) = 2
#   Gus   out(): Vincent (KNOWS) = 1
#   Vincent out(): none
#   Alix  in(): none
#   Gus   in(KNOWS): Alix
#   Vincent in(KNOWS): Gus
#   Grafeo OSS in(WORKS_AT): Alix

meta:
  language: gremlin
  model: lpg
  section: "traversal-patterns"
  title: Traversal Patterns
  dataset: social_network

tests:

  # ---------------------------------------------------------------------------
  # skip() - pagination via skip
  # ---------------------------------------------------------------------------

  - name: skip_with_order_by_age_asc
    # Ordered by age asc: Gus(25), Alix(30), Vincent(35). Skip 1 = Alix, Vincent.
    query: "g.V().hasLabel('Person').order().by('age', asc).skip(1).values('name')"
    expect:
      ordered: true
      rows:
        - [Alix]
        - [Vincent]

  - name: skip_all_returns_empty
    # 3 persons, skip 10 = empty
    query: "g.V().hasLabel('Person').skip(10)"
    expect:
      empty: true

  - name: skip_zero_returns_all
    # skip(0) should return all 3 persons
    query: "g.V().hasLabel('Person').skip(0).count()"
    expect:
      rows:
        - [3]

  - name: skip_with_limit_middle_element
    # Ordered by age asc: Gus(25), Alix(30), Vincent(35). Skip 1, limit 1 = Alix.
    query: "g.V().hasLabel('Person').order().by('age', asc).skip(1).limit(1).values('name')"
    expect:
      rows:
        - [Alix]

  - name: skip_exact_count
    # 3 persons, skip exactly 3 = empty
    query: "g.V().hasLabel('Person').skip(3)"
    expect:
      empty: true

  - name: skip_one_from_single_result
    # Alix out(KNOWS) = Gus (1 result), skip 1 = empty
    query: "g.V().has('Person', 'name', 'Alix').out('KNOWS').skip(1)"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # hasId() - filter by element ID
  # ---------------------------------------------------------------------------

  - name: has_id_nonexistent
    # ID 999999 should not match any vertex
    query: "g.V().hasId(999999)"
    expect:
      empty: true

  - name: has_id_returns_known_vertex
    # Verify that querying a known vertex by its ID returns exactly 1 result.
    # We extract the ID of Alix and then filter by it.
    statements:
      - "g.V().has('Person', 'name', 'Alix').id()"
    expect:
      count: 1

  - name: has_id_on_edges_nonexistent
    query: "g.E().hasId(999999)"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # Multi-hop traversal chains
  # ---------------------------------------------------------------------------

  - name: two_hop_knows_chain
    # Alix -> Gus -> Vincent
    query: "g.V().has('Person', 'name', 'Alix').out('KNOWS').out('KNOWS').values('name')"
    expect:
      rows:
        - [Vincent]

  - name: round_trip_out_in
    # Alix -> Gus via KNOWS, then back in(KNOWS) = Alix
    query: "g.V().has('Person', 'name', 'Alix').out('KNOWS').in('KNOWS').values('name')"
    expect:
      rows:
        - [Alix]

  - name: dead_end_no_outgoing
    # Vincent has no outgoing KNOWS edges
    query: "g.V().has('Person', 'name', 'Vincent').out('KNOWS')"
    expect:
      empty: true

  - name: dead_end_no_outgoing_count
    # Vincent has no outgoing edges of any type
    query: "g.V().has('Person', 'name', 'Vincent').out().count()"
    expect:
      rows:
        - [0]

  - name: three_hop_dead_end
    skip: "3-hop traversal ending in empty causes Column not found error"
    # Alix -> Gus -> Vincent -> (nothing). 3-hop from Alix is empty.
    query: "g.V().has('Person', 'name', 'Alix').out('KNOWS').out('KNOWS').out('KNOWS')"
    expect:
      empty: true

  - name: two_hop_with_filter
    # Alix -> Gus (age 25, passes gt(20)) -> Vincent
    query: "g.V().has('Person', 'name', 'Alix').out('KNOWS').has('age', gt(20)).out('KNOWS').values('name')"
    expect:
      rows:
        - [Vincent]

  - name: two_hop_filter_blocks_traversal
    # Alix -> Gus (age 25, fails gt(30)) -> nothing (filter blocks continuation)
    query: "g.V().has('Person', 'name', 'Alix').out('KNOWS').has('age', gt(30)).out('KNOWS')"
    expect:
      empty: true

  - name: in_chain_two_hops
    # Vincent <- Gus <- Alix (following KNOWS edges backwards)
    query: "g.V().has('Person', 'name', 'Vincent').in('KNOWS').in('KNOWS').values('name')"
    expect:
      rows:
        - [Alix]

  - name: mixed_direction_traversal
    # Gus in(KNOWS) = Alix, then Alix out(WORKS_AT) = Grafeo OSS
    query: "g.V().has('Person', 'name', 'Gus').in('KNOWS').out('WORKS_AT').values('name')"
    expect:
      rows:
        - [Grafeo OSS]

  # ---------------------------------------------------------------------------
  # as()/select() complex patterns
  # ---------------------------------------------------------------------------

  - name: as_select_with_values_name
    # Label Alix as 'a', traverse to Gus, select 'a' (Alix), get name
    query: "g.V().has('Person', 'name', 'Alix').as('a').out('KNOWS').select('a').values('name')"
    expect:
      rows:
        - [Alix]

  - name: as_select_two_labels
    # Label Alix as 'a', traverse to Gus and label as 'b', select both
    # Alix out(KNOWS) = Gus, so 1 pair
    query: "g.V().has('Person', 'name', 'Alix').as('a').out('KNOWS').as('b').select('a', 'b')"
    expect:
      count: 1

  - name: as_select_three_labels
    # Alix(start) -> Gus(mid) -> Vincent(end)
    query: "g.V().has('Person', 'name', 'Alix').as('start').out('KNOWS').as('mid').out('KNOWS').as('end').select('start', 'end')"
    expect:
      count: 1

  - name: as_select_three_labels_all
    # Alix(start) -> Gus(mid) -> Vincent(end), select all three
    query: "g.V().has('Person', 'name', 'Alix').as('start').out('KNOWS').as('mid').out('KNOWS').as('end').select('start', 'mid', 'end')"
    expect:
      count: 1

  - name: as_select_from_all_persons
    # For each Person with outgoing KNOWS: Alix->Gus, Gus->Vincent = 2 pairs
    query: "g.V().hasLabel('Person').as('src').out('KNOWS').as('dst').select('src', 'dst')"
    expect:
      count: 2

  - name: as_select_dead_end_produces_nothing
    # Vincent has no outgoing KNOWS, so as/select produces no results from Vincent
    query: "g.V().has('Person', 'name', 'Vincent').as('a').out('KNOWS').as('b').select('a', 'b')"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # Traversal depth edge cases
  # ---------------------------------------------------------------------------

  - name: single_vertex_no_edges
    # Vincent has no outgoing edges of any type
    query: "g.V().has('Person', 'name', 'Vincent').out()"
    expect:
      empty: true

  - name: all_persons_out_knows_count
    # Alix->Gus (1) + Gus->Vincent (1) + Vincent->(0) = 2
    query: "g.V().hasLabel('Person').out('KNOWS').count()"
    expect:
      rows:
        - [2]

  - name: bidirectional_gus_knows
    # Gus both(KNOWS): in from Alix + out to Vincent = 2
    query: "g.V().has('Person', 'name', 'Gus').both('KNOWS').count()"
    expect:
      rows:
        - [2]

  - name: bidirectional_gus_knows_names
    # Gus both(KNOWS): Alix (in) and Vincent (out)
    query: "g.V().has('Person', 'name', 'Gus').both('KNOWS').values('name')"
    expect:
      rows:
        - [Alix]
        - [Vincent]

  - name: bidirectional_alix_all
    # Alix both(): KNOWS out to Gus + WORKS_AT out to Grafeo OSS = 2
    # (Alix has no incoming edges)
    query: "g.V().has('Person', 'name', 'Alix').both().count()"
    expect:
      rows:
        - [2]

  - name: bidirectional_grafeo_oss
    # Grafeo OSS both(): only WORKS_AT in from Alix = 1
    query: "g.V().has('Company', 'name', 'Grafeo OSS').both().count()"
    expect:
      rows:
        - [1]

  - name: all_vertices_out_count
    # Alix out 2 + Gus out 1 + Vincent out 0 + Grafeo OSS out 0 = 3
    query: "g.V().out().count()"
    expect:
      rows:
        - [3]

  - name: all_vertices_in_count
    # Alix in 0 + Gus in 1 + Vincent in 1 + Grafeo OSS in 1 = 3
    query: "g.V().in().count()"
    expect:
      rows:
        - [3]

  # ---------------------------------------------------------------------------
  # range() edge cases
  # ---------------------------------------------------------------------------

  - name: range_zero_zero_empty
    # range(0, 0) should return nothing
    query: "g.V().hasLabel('Person').range(0, 0)"
    expect:
      empty: true

  - name: range_zero_one_first
    # range(0, 1) should return exactly 1 vertex
    query: "g.V().hasLabel('Person').range(0, 1)"
    expect:
      count: 1

  - name: range_beyond_size
    # 3 persons, range(0, 100) returns all 3
    query: "g.V().hasLabel('Person').range(0, 100)"
    expect:
      count: 3

  - name: range_with_order_precise_slice
    # Ordered by age asc: Gus(25), Alix(30), Vincent(35)
    # range(0, 2) = Gus, Alix
    query: "g.V().hasLabel('Person').order().by('age', asc).range(0, 2).values('name')"
    expect:
      ordered: true
      rows:
        - [Gus]
        - [Alix]

  - name: range_with_order_last_element
    # Ordered by age asc: Gus(25), Alix(30), Vincent(35)
    # range(2, 3) = Vincent
    query: "g.V().hasLabel('Person').order().by('age', asc).range(2, 3).values('name')"
    expect:
      rows:
        - [Vincent]

  - name: range_with_order_middle
    # Ordered by age asc: Gus(25), Alix(30), Vincent(35)
    # range(1, 2) = Alix
    query: "g.V().hasLabel('Person').order().by('age', asc).range(1, 2).values('name')"
    expect:
      rows:
        - [Alix]

  - name: range_start_equals_end_empty
    # range(2, 2) should return nothing (zero-width window)
    query: "g.V().hasLabel('Person').range(2, 2)"
    expect:
      empty: true

  - name: range_start_beyond_size_empty
    # 3 persons, range(5, 10) = empty
    query: "g.V().hasLabel('Person').range(5, 10)"
    expect:
      empty: true

  - name: range_on_edges
    # 3 edges total, range(1, 3) = 2 edges
    query: "g.E().range(1, 3)"
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # limit() edge cases
  # ---------------------------------------------------------------------------

  - name: limit_zero_empty
    # limit(0) should return nothing
    query: "g.V().hasLabel('Person').limit(0)"
    expect:
      empty: true

  - name: limit_larger_than_result
    # 3 persons, limit(100) returns all 3
    query: "g.V().hasLabel('Person').limit(100)"
    expect:
      count: 3

  - name: limit_one_with_order_asc
    # Ordered by age asc: Gus(25) is first
    query: "g.V().hasLabel('Person').order().by('age', asc).limit(1).values('name')"
    expect:
      rows:
        - [Gus]

  - name: limit_one_with_order_desc
    # Ordered by age desc: Vincent(35) is first
    query: "g.V().hasLabel('Person').order().by('age', desc).limit(1).values('name')"
    expect:
      rows:
        - [Vincent]

  - name: limit_exact_count
    # 3 persons, limit(3) returns all
    query: "g.V().hasLabel('Person').limit(3).count()"
    expect:
      rows:
        - [3]

  - name: limit_on_edges
    # 3 edges, limit(2)
    query: "g.E().limit(2)"
    expect:
      count: 2

  - name: limit_after_traversal
    # Alix out() = 2 results (Gus + Grafeo OSS), limit(1) = 1
    query: "g.V().has('Person', 'name', 'Alix').out().limit(1)"
    expect:
      count: 1

  # ---------------------------------------------------------------------------
  # Combined pagination patterns
  # ---------------------------------------------------------------------------

  - name: order_skip_limit_pagination
    # Page 2 of size 1, ordered by age asc: Gus(25), [Alix(30)], Vincent(35)
    query: "g.V().hasLabel('Person').order().by('age', asc).skip(1).limit(1).values('name')"
    expect:
      rows:
        - [Alix]

  - name: order_range_same_as_skip_limit
    # range(1, 2) is equivalent to skip(1).limit(1)
    query: "g.V().hasLabel('Person').order().by('age', asc).range(1, 2).values('name')"
    expect:
      rows:
        - [Alix]

  - name: filter_then_limit
    # Persons with age >= 30: Alix(30), Vincent(35). Limit 1 = 1 result.
    query: "g.V().hasLabel('Person').has('age', gte(30)).limit(1)"
    expect:
      count: 1

  - name: traversal_then_skip_limit
    # All persons out(KNOWS): Gus, Vincent (2 results). Skip 1, limit 1 = 1 result.
    query: "g.V().hasLabel('Person').out('KNOWS').skip(1).limit(1)"
    expect:
      count: 1
