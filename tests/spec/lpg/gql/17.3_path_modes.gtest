# GQL Path Modes: ISO/IEC 39075:2024 sec 17.3
#
# Covers: TRAIL mode, SIMPLE mode, ACYCLIC mode, parenthesized path
# patterns with quantifiers, WHERE inside parenthesized patterns.
#
# Many of these features are not yet fully implemented. Tests that require
# unimplemented syntax are marked with skip.

meta:
  language: gql
  model: lpg
  section: "17.3"
  title: Path modes
  dataset: empty

tests:

  # ---------------------------------------------------------------------------
  # TRAIL mode (no repeated edges)
  # ---------------------------------------------------------------------------

  - name: trail_mode_parenthesized
    setup:
      - "INSERT (:Person {name: 'Alix', age: 30})"
      - "INSERT (:Person {name: 'Gus', age: 25})"
      - "INSERT (:Person {name: 'Vincent', age: 35})"
      - "MATCH (a:Person {name: 'Alix'}), (b:Person {name: 'Gus'}) INSERT (a)-[:KNOWS]->(b)"
      - "MATCH (b:Person {name: 'Gus'}), (c:Person {name: 'Vincent'}) INSERT (b)-[:KNOWS]->(c)"
    query: "MATCH (TRAIL (a)-[:KNOWS]->(b)){1,3} RETURN DISTINCT b.name AS name ORDER BY name"
    expect:
      ordered: true
      count: 2

  - name: trail_mode_standalone
    setup:
      - "INSERT (:Node {name: 'a'})"
      - "INSERT (:Node {name: 'b'})"
      - "INSERT (:Node {name: 'c'})"
      - "MATCH (a:Node {name: 'a'}), (b:Node {name: 'b'}) INSERT (a)-[:STEP]->(b)"
      - "MATCH (b:Node {name: 'b'}), (c:Node {name: 'c'}) INSERT (b)-[:STEP]->(c)"
      - "MATCH (c:Node {name: 'c'}), (a:Node {name: 'a'}) INSERT (c)-[:STEP]->(a)"
    query: "MATCH TRAIL (a:Node {name: 'a'})-[:STEP]->{1,6}(b:Node) RETURN b.name"
    expect:
      count: 3

  # ---------------------------------------------------------------------------
  # SIMPLE mode (no repeated nodes except possibly endpoints)
  # ---------------------------------------------------------------------------

  - name: simple_mode
    setup:
      - "INSERT (:Node {name: 'a'})"
      - "INSERT (:Node {name: 'b'})"
      - "INSERT (:Node {name: 'c'})"
      - "MATCH (a:Node {name: 'a'}), (b:Node {name: 'b'}) INSERT (a)-[:STEP]->(b)"
      - "MATCH (b:Node {name: 'b'}), (c:Node {name: 'c'}) INSERT (b)-[:STEP]->(c)"
      - "MATCH (c:Node {name: 'c'}), (a:Node {name: 'a'}) INSERT (c)-[:STEP]->(a)"
    query: "MATCH SIMPLE (a:Node {name: 'a'})-[:STEP]->{1,6}(b:Node) RETURN b.name"
    expect:
      count: 3

  # ---------------------------------------------------------------------------
  # ACYCLIC mode (no repeated nodes at all)
  # ---------------------------------------------------------------------------

  - name: acyclic_mode
    setup:
      - "INSERT (:Node {name: 'a'})"
      - "INSERT (:Node {name: 'b'})"
      - "INSERT (:Node {name: 'c'})"
      - "MATCH (a:Node {name: 'a'}), (b:Node {name: 'b'}) INSERT (a)-[:STEP]->(b)"
      - "MATCH (b:Node {name: 'b'}), (c:Node {name: 'c'}) INSERT (b)-[:STEP]->(c)"
      - "MATCH (c:Node {name: 'c'}), (a:Node {name: 'a'}) INSERT (c)-[:STEP]->(a)"
    query: "MATCH ACYCLIC (a:Node {name: 'a'})-[:STEP]->{1,6}(b:Node) RETURN b.name"
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # Parenthesized path patterns with WHERE
  # ---------------------------------------------------------------------------

  - name: parenthesized_where_filters_nodes
    setup:
      - "INSERT (:Person {name: 'Alix', age: 30})"
      - "INSERT (:Person {name: 'Gus', age: 25})"
      - "INSERT (:Person {name: 'Vincent', age: 35})"
      - "MATCH (a:Person {name: 'Alix'}), (b:Person {name: 'Gus'}) INSERT (a)-[:KNOWS]->(b)"
      - "MATCH (b:Person {name: 'Gus'}), (c:Person {name: 'Vincent'}) INSERT (b)-[:KNOWS]->(c)"
    query: "MATCH ((a:Person)-[:KNOWS]->(b:Person) WHERE b.age > 26){1,2} RETURN DISTINCT b.name AS name ORDER BY name"
    expect:
      ordered: true
      rows:
        - [Vincent]

  - name: parenthesized_trail_with_where
    setup:
      - "INSERT (:Person {name: 'Alix', age: 30})"
      - "INSERT (:Person {name: 'Gus', age: 25})"
      - "INSERT (:Person {name: 'Vincent', age: 35})"
      - "MATCH (a:Person {name: 'Alix'}), (b:Person {name: 'Gus'}) INSERT (a)-[:KNOWS]->(b)"
      - "MATCH (b:Person {name: 'Gus'}), (c:Person {name: 'Vincent'}) INSERT (b)-[:KNOWS]->(c)"
    query: "MATCH (TRAIL (a)-[e:KNOWS]->(b) WHERE b.age >= 25){1,3} RETURN DISTINCT b.name AS name ORDER BY name"
    expect:
      ordered: true
      count: 2

  # ---------------------------------------------------------------------------
  # WALK mode (allows repeated nodes and edges)
  # ---------------------------------------------------------------------------

  - name: walk_mode
    setup:
      - "INSERT (:Node {name: 'a'})"
      - "INSERT (:Node {name: 'b'})"
      - "INSERT (:Node {name: 'c'})"
      - "MATCH (a:Node {name: 'a'}), (b:Node {name: 'b'}) INSERT (a)-[:STEP]->(b)"
      - "MATCH (b:Node {name: 'b'}), (c:Node {name: 'c'}) INSERT (b)-[:STEP]->(c)"
      - "MATCH (c:Node {name: 'c'}), (a:Node {name: 'a'}) INSERT (c)-[:STEP]->(a)"
    query: "MATCH WALK (a:Node {name: 'a'})-[:STEP]->{1,4}(b:Node) RETURN b.name"
    expect:
      count: 4

  # ---------------------------------------------------------------------------
  # Path search prefixes
  # ---------------------------------------------------------------------------

  - name: any_path_search
    skip: "ANY path search prefix not implemented"
    setup:
      - "INSERT (:Node {name: 'a'})"
      - "INSERT (:Node {name: 'b'})"
      - "INSERT (:Node {name: 'c'})"
      - "INSERT (:Node {name: 'd'})"
      - "MATCH (a:Node {name: 'a'}), (b:Node {name: 'b'}) INSERT (a)-[:STEP]->(b)"
      - "MATCH (a:Node {name: 'a'}), (c:Node {name: 'c'}) INSERT (a)-[:STEP]->(c)"
      - "MATCH (b:Node {name: 'b'}), (d:Node {name: 'd'}) INSERT (b)-[:STEP]->(d)"
      - "MATCH (c:Node {name: 'c'}), (d:Node {name: 'd'}) INSERT (c)-[:STEP]->(d)"
    query: "MATCH ANY p = (a:Node {name: 'a'})-[:STEP]->{1,3}(d:Node {name: 'd'}) RETURN length(p) AS len"
    expect:
      count: 1

  - name: all_shortest_path_search
    setup:
      - "INSERT (:Node {name: 'a'})"
      - "INSERT (:Node {name: 'b'})"
      - "INSERT (:Node {name: 'c'})"
      - "INSERT (:Node {name: 'd'})"
      - "MATCH (a:Node {name: 'a'}), (b:Node {name: 'b'}) INSERT (a)-[:STEP]->(b)"
      - "MATCH (a:Node {name: 'a'}), (c:Node {name: 'c'}) INSERT (a)-[:STEP]->(c)"
      - "MATCH (b:Node {name: 'b'}), (d:Node {name: 'd'}) INSERT (b)-[:STEP]->(d)"
      - "MATCH (c:Node {name: 'c'}), (d:Node {name: 'd'}) INSERT (c)-[:STEP]->(d)"
    query: "MATCH p = ALL SHORTEST (a:Node {name: 'a'})-[:STEP]->+(d:Node {name: 'd'}) RETURN length(p) AS len"
    expect:
      count: 2

  - name: any_shortest_path_search
    skip: "ANY SHORTEST path search prefix not implemented"
    setup:
      - "INSERT (:Node {name: 'a'})"
      - "INSERT (:Node {name: 'b'})"
      - "INSERT (:Node {name: 'c'})"
      - "INSERT (:Node {name: 'd'})"
      - "MATCH (a:Node {name: 'a'}), (b:Node {name: 'b'}) INSERT (a)-[:STEP]->(b)"
      - "MATCH (a:Node {name: 'a'}), (c:Node {name: 'c'}) INSERT (a)-[:STEP]->(c)"
      - "MATCH (b:Node {name: 'b'}), (d:Node {name: 'd'}) INSERT (b)-[:STEP]->(d)"
      - "MATCH (c:Node {name: 'c'}), (d:Node {name: 'd'}) INSERT (c)-[:STEP]->(d)"
    query: "MATCH p = ANY SHORTEST (a:Node {name: 'a'})-[:STEP]->+(d:Node {name: 'd'}) RETURN length(p) AS len"
    expect:
      count: 1
