# GraphQL queries on RDF-like data
#
# Covers: type-based queries, field selection, shorthand syntax,
# filters, pagination (first/skip), ordering (orderBy),
# nested traversals, multi-label queries.

meta:
  language: graphql
  model: rdf
  section: queries
  title: GraphQL queries on RDF data
  dataset: rdf_social
  requires: [graphql]

tests:

  # ---------------------------------------------------------------------------
  # Basic type queries
  # ---------------------------------------------------------------------------

  - name: query_all_resources
    query: "query { resource { uri name } }"
    expect:
      count: 6

  - name: query_all_persons
    query: "query { person { name age } }"
    expect:
      count: 5

  - name: query_all_organizations
    query: "query { organization { name founded } }"
    expect:
      count: 1

  - name: query_single_field
    query: "query { person { name } }"
    expect:
      count: 5

  - name: query_multiple_fields
    query: "query { person { name age city email } }"
    expect:
      count: 5

  # ---------------------------------------------------------------------------
  # Shorthand query syntax (no "query" keyword)
  # ---------------------------------------------------------------------------

  - name: shorthand_query
    query: "{ person { name } }"
    expect:
      count: 5

  - name: shorthand_with_filter
    query: "{ person(name: \"Alix\") { name age } }"
    expect:
      rows:
        - [Alix, 30]

  # ---------------------------------------------------------------------------
  # Equality filters
  # ---------------------------------------------------------------------------

  - name: filter_by_name
    query: "{ person(name: \"Alix\") { name age } }"
    expect:
      rows:
        - [Alix, 30]

  - name: filter_by_age
    query: "{ person(age: 25) { name } }"
    expect:
      rows:
        - [Gus]

  - name: filter_by_city
    query: "{ person(city: \"Amsterdam\") { name } }"
    expect:
      count: 2

  - name: filter_resource_by_uri
    query: |
      query {
        resource(uri: "http://example.org/person/alix") {
          name
          age
        }
      }
    expect:
      rows:
        - [Alix, 30]

  - name: filter_no_match
    query: "{ person(name: \"Nobody\") { name } }"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # Filter object syntax
  # ---------------------------------------------------------------------------

  - name: filter_object_by_age
    query: "query { person(filter: { age: 30 }) { name } }"
    expect:
      rows:
        - [Alix]

  - name: filter_object_by_city
    query: "query { person(filter: { city: \"Berlin\" }) { name } }"
    expect:
      rows:
        - [Gus]

  # ---------------------------------------------------------------------------
  # Pagination
  # ---------------------------------------------------------------------------

  - name: first_limits_results
    query: "{ person(first: 2) { name } }"
    expect:
      count: 2

  - name: limit_alias
    query: "{ person(limit: 3) { name } }"
    expect:
      count: 3

  - name: skip_offsets_results
    query: "{ person(first: 2, skip: 2) { name } }"
    expect:
      count: 2

  - name: offset_alias
    query: "{ person(limit: 2, offset: 1) { name } }"
    expect:
      count: 2

  - name: first_exceeds_total
    query: "{ person(first: 100) { name } }"
    expect:
      count: 5

  # ---------------------------------------------------------------------------
  # Ordering
  # ---------------------------------------------------------------------------

  - name: order_by_name_asc
    query: |
      query {
        person(orderBy: { name: ASC }) {
          name
        }
      }
    expect:
      ordered: true
      rows:
        - [Alix]
        - [Gus]
        - [Jules]
        - [Mia]
        - [Vincent]

  - name: order_by_age_desc
    query: |
      query {
        person(orderBy: { age: DESC }) {
          name
          age
        }
      }
    expect:
      ordered: true
      rows:
        - [Vincent, 35]
        - [Mia, 32]
        - [Alix, 30]
        - [Jules, 28]
        - [Gus, 25]

  - name: order_by_with_first
    query: |
      query {
        person(orderBy: { age: ASC }, first: 3) {
          name
          age
        }
      }
    expect:
      ordered: true
      rows:
        - [Gus, 25]
        - [Jules, 28]
        - [Alix, 30]

  - name: order_by_with_skip_and_first
    query: |
      query {
        person(orderBy: { age: ASC }, skip: 1, first: 2) {
          name
          age
        }
      }
    expect:
      ordered: true
      rows:
        - [Jules, 28]
        - [Alix, 30]

  # ---------------------------------------------------------------------------
  # Nested traversals
  # ---------------------------------------------------------------------------

  - name: nested_knows_traversal
    query: |
      query {
        person {
          name
          knows {
            name
          }
        }
      }
    expect:
      count: 5

  - name: nested_knows_with_parent_filter
    query: |
      query {
        person(name: "Alix") {
          name
          knows {
            name
          }
        }
      }
    expect:
      count: 2

  - name: nested_works_at_traversal
    query: |
      query {
        person(name: "Alix") {
          name
          works_at {
            name
          }
        }
      }
    expect:
      count: 1

  - name: nested_with_filter_on_target
    query: |
      query {
        person(name: "Alix") {
          name
          knows(age: 25) {
            name
            age
          }
        }
      }
    expect:
      count: 1

  - name: nested_no_relationships
    # Mia has no outgoing knows edges
    query: |
      query {
        person(name: "Mia") {
          name
          knows {
            name
          }
        }
      }
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # Fragment spreads
  # ---------------------------------------------------------------------------

  - name: fragment_spread_basic
    query: |
      fragment PersonFields on Person { name age }
      query { person { ...PersonFields } }
    expect:
      count: 5

  - name: fragment_spread_subset
    query: |
      fragment NameOnly on Person { name }
      query { person { ...NameOnly } }
    expect:
      count: 5

  # ---------------------------------------------------------------------------
  # Inline fragments with type condition
  # ---------------------------------------------------------------------------

  - name: inline_fragment_with_type
    query: "query { person { ... on Person { name age } } }"
    expect:
      count: 5

  # ---------------------------------------------------------------------------
  # Field aliases
  # ---------------------------------------------------------------------------

  - name: field_alias_single
    query: "{ person(name: \"Alix\") { personName: name } }"
    expect:
      columns: [personName]
      rows:
        - [Alix]

  - name: field_alias_multiple
    query: "{ person(name: \"Gus\") { n: name a: age } }"
    expect:
      columns: [n, a]
      rows:
        - [Gus, 25]

  # ---------------------------------------------------------------------------
  # Named query syntax
  # ---------------------------------------------------------------------------

  - name: named_query_syntax
    query: "query GetPeople { person { name } }"
    expect:
      count: 5

  # ---------------------------------------------------------------------------
  # Shorthand with multiple fields
  # ---------------------------------------------------------------------------

  - name: shorthand_multiple_fields
    query: "{ person { name age city } }"
    expect:
      count: 5

  # ---------------------------------------------------------------------------
  # Nested traversal with alias
  # ---------------------------------------------------------------------------

  - name: nested_traversal_alias
    query: |
      query {
        person(name: "Alix") {
          name
          friends: knows {
            name
          }
        }
      }
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # Empty result cases
  # ---------------------------------------------------------------------------

  - name: nonexistent_type
    query: "{ animal { name } }"
    expect:
      empty: true

  - name: filter_no_match_django
    query: "{ person(name: \"Django\") { name } }"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # Multiple operations (first used)
  # ---------------------------------------------------------------------------

  - name: multiple_operations_first_used
    query: "query A { person { name } } query B { organization { name } }"
    expect:
      count: 5

  # ---------------------------------------------------------------------------
  # Block string in query
  # ---------------------------------------------------------------------------

  - name: block_string_in_query
    setup:
      - "INSERT (:Resource:Person {uri: 'http://example.org/person/hans', name: 'Hans', age: 33, city: 'Berlin', bio: 'A long bio'})"
    query: "{ person(name: \"Hans\") { name bio } }"
    expect:
      rows:
        - [Hans, A long bio]

  # ---------------------------------------------------------------------------
  # Additional empty result cases
  # ---------------------------------------------------------------------------

  - name: filter_no_match_age
    query: "{ person(age: 999) { name } }"
    expect:
      empty: true
