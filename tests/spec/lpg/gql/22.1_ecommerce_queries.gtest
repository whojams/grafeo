# GQL E-Commerce Real-World Queries
#
# Covers: multi-hop traversals, aggregation through relationships,
# recommendation patterns, customer analytics, temporal filtering.
# Uses ecommerce dataset for production-realistic query patterns.

meta:
  language: gql
  model: lpg
  section: "22.1"
  title: E-commerce real-world queries
  dataset: ecommerce

tests:

  # ---------------------------------------------------------------------------
  # Customer analytics
  # ---------------------------------------------------------------------------

  - name: customer_order_summary
    query: |
      MATCH (c:Customer)-[:PLACED]->(o:Order)
      RETURN c.name, count(o) AS orders, sum(o.total) AS total_spend
      ORDER BY total_spend DESC
    expect:
      ordered: true
      precision: 2
      rows:
        - [Alix, 2, 2689.97]
        - [Vincent, 2, 589.97]
        - [Gus, 2, 179.97]
        - [Mia, 1, 129.99]
        - [Jules, 1, 49.99]

  - name: gold_tier_spending
    query: |
      MATCH (c:Customer)-[:PLACED]->(o:Order)
      WHERE c.tier = 'gold' AND o.status = 'delivered'
      RETURN c.name, sum(o.total) AS delivered_spend
      ORDER BY delivered_spend DESC
    expect:
      ordered: true
      precision: 2
      rows:
        - [Alix, 2689.97]
        - [Vincent, 549.98]

  - name: customers_by_city_with_order_count
    query: |
      MATCH (c:Customer)-[:PLACED]->(o:Order)
      RETURN c.city, count(DISTINCT c) AS customers, count(o) AS total_orders
      ORDER BY c.city
    expect:
      ordered: true
      rows:
        - [Amsterdam, 2, 3]
        - [Berlin, 1, 2]
        - [Paris, 1, 2]
        - [Prague, 1, 1]

  # ---------------------------------------------------------------------------
  # Product analytics
  # ---------------------------------------------------------------------------

  - name: products_ordered_most
    query: |
      MATCH (o:Order)-[:CONTAINS]->(p:Product)
      RETURN p.name, count(o) AS times_ordered
      ORDER BY times_ordered DESC, p.name
    expect:
      ordered: true
      rows:
        - [Graph Databases, 3]
        - [Laptop Pro, 2]
        - [Rust Programming, 2]
        - [Wireless Headphones, 2]
        - [Tablet Mini, 1]
        - [Winter Jacket, 1]

  - name: avg_review_score_per_product
    query: |
      MATCH (c:Customer)-[r:REVIEWED]->(p:Product)
      RETURN p.name, avg(r.rating) AS avg_rating, count(r) AS review_count
      ORDER BY avg_rating DESC, p.name
    expect:
      ordered: true
      precision: 1
      rows:
        - [Graph Databases, 5.0, 2]
        - [Laptop Pro, 5.0, 1]
        - [Tablet Mini, 4.0, 1]
        - [Wireless Headphones, 3.5, 2]

  - name: products_never_reviewed
    query: |
      MATCH (p:Product)
      WHERE NOT EXISTS { MATCH (:Customer)-[:REVIEWED]->(p) }
      RETURN p.name ORDER BY p.name
    expect:
      ordered: true
      rows:
        - [Rust Programming]
        - [Winter Jacket]

  # ---------------------------------------------------------------------------
  # Multi-hop: customer -> order -> product -> category
  # ---------------------------------------------------------------------------

  - name: categories_per_customer
    query: |
      MATCH (c:Customer)-[:PLACED]->(o:Order)-[:CONTAINS]->(p:Product)-[:IN_CATEGORY]->(cat:Category)
      RETURN c.name, collect(DISTINCT cat.name) AS categories
      ORDER BY c.name
    expect:
      ordered: true
      count: 5

  - name: revenue_by_category
    skip: "count(DISTINCT) through multi-hop"
    query: |
      MATCH (o:Order)-[:CONTAINS]->(p:Product)-[:IN_CATEGORY]->(cat:Category)
      WHERE o.status = 'delivered'
      RETURN cat.name, count(DISTINCT o) AS order_count
      ORDER BY order_count DESC
    expect:
      ordered: true
      count: 3

  # ---------------------------------------------------------------------------
  # Recommendation: customers who bought X also bought Y
  # ---------------------------------------------------------------------------

  - name: also_bought_pattern
    query: |
      MATCH (c:Customer)-[:PLACED]->(o1:Order)-[:CONTAINS]->(p1:Product {name: 'Laptop Pro'}),
            (c)-[:PLACED]->(o2:Order)-[:CONTAINS]->(p2:Product)
      WHERE p2.name <> 'Laptop Pro'
      RETURN DISTINCT p2.name AS also_bought ORDER BY p2.name
    expect:
      ordered: true
      rows:
        - [Wireless Headphones]

  - name: customers_who_bought_both_books
    skip: "multi-pattern MATCH with different orders"
    query: |
      MATCH (c:Customer)-[:PLACED]->(o1:Order)-[:CONTAINS]->(p1:Product {name: 'Graph Databases'}),
            (c)-[:PLACED]->(o2:Order)-[:CONTAINS]->(p2:Product {name: 'Rust Programming'})
      RETURN DISTINCT c.name ORDER BY c.name
    expect:
      ordered: true
      rows:
        - [Gus]

  # ---------------------------------------------------------------------------
  # Order status analytics
  # ---------------------------------------------------------------------------

  - name: order_status_breakdown
    query: |
      MATCH (o:Order)
      RETURN o.status, count(o) AS cnt, sum(o.total) AS total_value
      ORDER BY cnt DESC, o.status
    expect:
      ordered: true
      precision: 2
      rows:
        - [delivered, 5, 3419.93]
        - [cancelled, 1, 39.99]
        - [pending, 1, 129.99]
        - [shipped, 1, 49.99]

  # ---------------------------------------------------------------------------
  # Customer-product affinity
  # ---------------------------------------------------------------------------

  - name: customer_reviewed_what_they_ordered
    skip: "multi-pattern MATCH produces duplicate rows from path multiplicity"
    query: |
      MATCH (c:Customer)-[:PLACED]->(o:Order)-[:CONTAINS]->(p:Product),
            (c)-[r:REVIEWED]->(p)
      RETURN c.name, p.name, r.rating ORDER BY c.name, p.name
    expect:
      ordered: true
      rows:
        - [Alix, Laptop Pro, 5]
        - [Alix, Wireless Headphones, 4]
        - [Vincent, Graph Databases, 5]
        - [Vincent, Tablet Mini, 4]

  - name: ordered_but_not_reviewed
    skip: "NOT EXISTS with multi-hop pattern"
    query: |
      MATCH (c:Customer)-[:PLACED]->(o:Order)-[:CONTAINS]->(p:Product)
      WHERE NOT EXISTS { MATCH (c)-[:REVIEWED]->(p) }
      RETURN DISTINCT c.name, p.name ORDER BY c.name, p.name
    expect:
      ordered: true
      count: 7

  # ---------------------------------------------------------------------------
  # Price range queries
  # ---------------------------------------------------------------------------

  - name: products_in_price_range
    query: |
      MATCH (p:Product)
      WHERE p.price >= 40 AND p.price <= 100
      RETURN p.name, p.price ORDER BY p.price
    expect:
      ordered: true
      rows:
        - [Graph Databases, 49.99]
        - [Wireless Headphones, 89.99]

  - name: category_price_statistics
    query: |
      MATCH (p:Product)-[:IN_CATEGORY]->(c:Category)
      RETURN c.name, count(p) AS cnt, min(p.price) AS cheapest, max(p.price) AS most_expensive, avg(p.price) AS avg_price
      ORDER BY c.name
    expect:
      ordered: true
      precision: 2
      rows:
        - [Books, 2, 39.99, 49.99, 44.99]
        - [Clothing, 1, 129.99, 129.99, 129.99]
        - [Electronics, 3, 89.99, 1299.99, 629.99]
