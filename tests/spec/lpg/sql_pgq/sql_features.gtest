# SQL/PGQ SQL-level features
#
# Covers: CASE expressions, outer SELECT projection, ORDER BY on aggregates,
# WITH/CTE, set operations (UNION/INTERSECT/EXCEPT), window functions,
# scalar subqueries, HAVING edge cases, DISTINCT + ORDER BY edge cases.

meta:
  language: sql-pgq
  model: lpg
  section: "4.39"
  title: SQL-level features
  dataset: social_network

tests:

  # ---------------------------------------------------------------------------
  # CASE expressions (searched, simple, without ELSE, with NULL)
  # ---------------------------------------------------------------------------

  - name: case_searched_age_category
    skip: "CASE expression not yet supported in SQL/PGQ parser"
    query: |
      SELECT * FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name, n.age AS age)
      ) AS g
      WHERE CASE WHEN g.age >= 30 THEN 'senior' ELSE 'junior' END = 'senior'
    expect:
      rows:
        - [Alix, 30]
        - [Vincent, 35]

  - name: case_searched_in_select
    skip: "CASE expression not yet supported in SQL/PGQ parser"
    query: |
      SELECT name, CASE WHEN age >= 30 THEN 'senior' ELSE 'junior' END AS category
      FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name, n.age AS age)
      )
    expect:
      rows:
        - [Alix, senior]
        - [Gus, junior]
        - [Vincent, senior]

  - name: case_simple_city_to_country
    skip: "CASE expression not yet supported in SQL/PGQ parser"
    query: |
      SELECT name, CASE city
        WHEN 'Amsterdam' THEN 'NL'
        WHEN 'Berlin' THEN 'DE'
        ELSE 'other'
      END AS country
      FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name, n.city AS city)
      )
    expect:
      rows:
        - [Alix, NL]
        - [Gus, DE]
        - [Vincent, other]

  - name: case_without_else_returns_null
    skip: "CASE expression not yet supported in SQL/PGQ parser"
    query: |
      SELECT name, CASE city
        WHEN 'Amsterdam' THEN 'NL'
        WHEN 'Berlin' THEN 'DE'
      END AS country
      FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name, n.city AS city)
      )
    expect:
      rows:
        - [Alix, NL]
        - [Gus, DE]
        - [Vincent, null]

  - name: case_null_check
    skip: "CASE expression not yet supported in SQL/PGQ parser"
    query: |
      SELECT person, CASE WHEN company IS NULL THEN 'unemployed' ELSE company END AS status
      FROM GRAPH_TABLE (
        MATCH (p:Person)
        OPTIONAL MATCH (p)-[w:WORKS_AT]->(c:Company)
        COLUMNS (p.name AS person, c.name AS company)
      )
    expect:
      rows:
        - [Alix, Grafeo OSS]
        - [Gus, unemployed]
        - [Vincent, unemployed]

  # ---------------------------------------------------------------------------
  # Outer SELECT projection (column subset, alias renaming, qualified names)
  # ---------------------------------------------------------------------------

  - name: outer_select_single_column_from_multi
    skip: "outer SELECT projection not yet implemented, returns all COLUMNS"
    query: |
      SELECT name FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name, n.age AS age, n.city AS city)
      )
    expect:
      rows:
        - [Alix]
        - [Gus]
        - [Vincent]

  - name: outer_select_alias_rename
    skip: "outer SELECT projection not yet implemented, returns all COLUMNS"
    query: |
      SELECT name AS person_name FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name, n.age AS age)
      )
    expect:
      rows:
        - [Alix]
        - [Gus]
        - [Vincent]

  - name: outer_select_qualified_subset
    skip: "outer SELECT projection not yet implemented, returns all COLUMNS"
    query: |
      SELECT g.name, g.city FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name, n.age AS age, n.city AS city)
      ) AS g
    expect:
      rows:
        - [Alix, Amsterdam]
        - [Gus, Berlin]
        - [Vincent, Paris]

  # ---------------------------------------------------------------------------
  # ORDER BY on aggregate aliases
  # ---------------------------------------------------------------------------

  - name: order_by_count_alias_desc
    skip: "ORDER BY on aggregate alias not yet implemented"
    query: |
      SELECT city, COUNT(*) AS cnt FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.city AS city)
      ) GROUP BY city ORDER BY cnt DESC
    expect:
      ordered: true
      rows:
        - [Amsterdam, 1]
        - [Berlin, 1]
        - [Paris, 1]

  - name: order_by_sum_alias
    skip: "ORDER BY on aggregate alias not yet implemented"
    query: |
      SELECT source, SUM(year) AS total FROM GRAPH_TABLE (
        MATCH (a:Person)-[e:KNOWS]->(b:Person)
        COLUMNS (a.name AS source, e.since AS year)
      ) GROUP BY source ORDER BY total ASC
    expect:
      ordered: true
      rows:
        - [Alix, 2020]
        - [Gus, 2021]

  # ---------------------------------------------------------------------------
  # WITH / CTE
  # ---------------------------------------------------------------------------

  - name: cte_wrapping_graph_table
    query: |
      WITH cte AS (
        SELECT * FROM GRAPH_TABLE (
          MATCH (n:Person)
          COLUMNS (n.name AS name, n.age AS age)
        )
      )
      SELECT * FROM cte
    expect:
      error: "WITH"

  # ---------------------------------------------------------------------------
  # Set operations: UNION, INTERSECT, EXCEPT
  # ---------------------------------------------------------------------------

  - name: union_two_graph_table_queries
    skip: "UNION not yet supported in SQL/PGQ parser"
    query: |
      SELECT * FROM GRAPH_TABLE (
        MATCH (n:Person)
        WHERE n.city = 'Amsterdam'
        COLUMNS (n.name AS name)
      )
      UNION
      SELECT * FROM GRAPH_TABLE (
        MATCH (n:Person)
        WHERE n.city = 'Berlin'
        COLUMNS (n.name AS name)
      )
    expect:
      count: 2

  - name: intersect_two_graph_table_queries
    skip: "INTERSECT not yet supported in SQL/PGQ parser"
    query: |
      SELECT * FROM GRAPH_TABLE (
        MATCH (n:Person)
        WHERE n.age >= 25
        COLUMNS (n.name AS name)
      )
      INTERSECT
      SELECT * FROM GRAPH_TABLE (
        MATCH (n:Person)
        WHERE n.age <= 30
        COLUMNS (n.name AS name)
      )
    expect:
      count: 2

  - name: except_two_graph_table_queries
    skip: "EXCEPT not yet supported in SQL/PGQ parser"
    query: |
      SELECT * FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name)
      )
      EXCEPT
      SELECT * FROM GRAPH_TABLE (
        MATCH (n:Person)
        WHERE n.city = 'Paris'
        COLUMNS (n.name AS name)
      )
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # Window functions
  # ---------------------------------------------------------------------------

  - name: window_row_number
    query: |
      SELECT name, ROW_NUMBER() OVER (ORDER BY age) AS rn FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name, n.age AS age)
      )
    expect:
      error: "OVER"

  - name: window_sum_over
    query: |
      SELECT name, SUM(age) OVER () AS total_age FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name, n.age AS age)
      )
    expect:
      error: "OVER"

  # ---------------------------------------------------------------------------
  # Subqueries
  # ---------------------------------------------------------------------------

  - name: scalar_subquery_in_where
    query: |
      SELECT * FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name, n.age AS age)
      ) AS g
      WHERE g.age > (SELECT AVG(age) FROM GRAPH_TABLE (
        MATCH (m:Person)
        COLUMNS (m.age AS age)
      ))
    expect:
      error: "Expected expression"

  # ---------------------------------------------------------------------------
  # HAVING edge cases
  # ---------------------------------------------------------------------------

  - name: having_without_group_by
    query: |
      SELECT COUNT(*) AS cnt FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name)
      ) HAVING cnt > 0
    expect:
      rows:
        - [3]

  - name: having_multiple_conditions
    query: |
      SELECT city, COUNT(*) AS cnt, SUM(age) AS total FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.city AS city, n.age AS age)
      ) GROUP BY city HAVING cnt >= 1 AND total > 20
    expect:
      rows:
        - [Amsterdam, 1, 30]
        - [Berlin, 1, 25]
        - [Paris, 1, 35]

  - name: having_inline_aggregate
    skip: "inline COUNT(*) in HAVING not resolved, only alias references work"
    query: |
      SELECT city FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.city AS city)
      ) GROUP BY city HAVING COUNT(*) > 0
    expect:
      rows:
        - [Amsterdam]
        - [Berlin]
        - [Paris]

  # ---------------------------------------------------------------------------
  # DISTINCT + ORDER BY edge cases
  # ---------------------------------------------------------------------------

  - name: distinct_with_order_by_same_column
    query: |
      SELECT DISTINCT city FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.city AS city)
      ) ORDER BY city ASC
    expect:
      ordered: true
      rows:
        - [Amsterdam]
        - [Berlin]
        - [Paris]

  - name: distinct_with_order_by_different_column
    query: |
      SELECT DISTINCT name, age FROM GRAPH_TABLE (
        MATCH (n:Person)
        COLUMNS (n.name AS name, n.age AS age)
      ) ORDER BY age DESC
    expect:
      ordered: true
      rows:
        - [Vincent, 35]
        - [Alix, 30]
        - [Gus, 25]
