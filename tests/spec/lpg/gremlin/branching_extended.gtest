# Gremlin extended branching: choose() with traversal conditions,
#                            choose() with hasKey, or() with mixed types,
#                            coalesce edge cases, where() with has()
#
# Covers branching and boolean combinator patterns not exercised elsewhere.
#
# Social network topology (from dataset):
#   Persons: Alix(30, Amsterdam), Gus(25, Berlin), Vincent(35, Paris)
#   Company: Grafeo OSS (founded 2025)
#   Edges: Alix-KNOWS->Gus, Gus-KNOWS->Vincent, Alix-WORKS_AT->Grafeo OSS

meta:
  language: gremlin
  model: lpg
  section: "branching-extended"
  title: Extended Branching
  dataset: social_network

tests:

  # ---------------------------------------------------------------------------
  # choose() with traversal condition (existence check)
  # ---------------------------------------------------------------------------

  - name: choose_traversal_out_knows
    # Alix has out('KNOWS') -> true branch, Gus has out('KNOWS') -> true branch,
    # Vincent has no out('KNOWS') -> false branch
    query: "g.V().hasLabel('Person').choose(out('KNOWS'), values('name'), constant('loner'))"
    expect:
      count: 3

  - name: choose_traversal_out_works_at
    # Alix has WORKS_AT -> constant('worker'), Gus and Vincent don't -> constant('free')
    query: "g.V().hasLabel('Person').choose(out('WORKS_AT'), constant('worker'), constant('free'))"
    expect:
      count: 3

  - name: choose_traversal_all_vertices
    # Applied to all 4 vertices. Alix+Gus have out('KNOWS'), Vincent+Grafeo OSS don't.
    query: "g.V().choose(out('KNOWS'), constant('connected'), constant('isolated'))"
    expect:
      count: 4

  # ---------------------------------------------------------------------------
  # choose() with has(key) condition (property existence)
  # ---------------------------------------------------------------------------

  - name: choose_has_key_founded
    # Grafeo OSS has 'founded', 3 Person vertices don't
    query: "g.V().choose(has('founded'), constant('company'), constant('person'))"
    expect:
      count: 4

  - name: choose_has_key_city
    # 3 Person vertices have 'city', Grafeo OSS doesn't
    query: "g.V().choose(has('city'), values('city'), constant('no city'))"
    expect:
      count: 4

  # ---------------------------------------------------------------------------
  # or() with mixed label and property filters
  # ---------------------------------------------------------------------------

  - name: or_mixed_label_property
    skip: "or() with hasLabel + has across types returns 1 instead of 2"
    query: "g.V().or(hasLabel('Company'), has('city', 'Paris')).count()"
    expect:
      rows:
        - [2]

  - name: or_same_property_different_values
    query: "g.V().hasLabel('Person').or(has('age', 25), has('age', 35)).values('name')"
    expect:
      rows:
        - [Gus]
        - [Vincent]

  - name: or_label_and_age
    skip: "or() with hasLabel + has across types returns 1 instead of 2"
    query: "g.V().or(hasLabel('Company'), has('age', gt(34))).count()"
    expect:
      rows:
        - [2]

  # ---------------------------------------------------------------------------
  # and() with label and property filters
  # ---------------------------------------------------------------------------

  - name: and_label_and_property
    query: "g.V().and(hasLabel('Person'), has('age', lt(30))).values('name')"
    expect:
      rows:
        - [Gus]

  - name: and_two_property_filters
    query: "g.V().and(has('age', gt(24)), has('city', 'Amsterdam')).values('name')"
    expect:
      rows:
        - [Alix]

  - name: and_three_conditions
    query: "g.V().and(hasLabel('Person'), has('age', gte(25)), has('age', lte(30))).values('name')"
    expect:
      rows:
        - [Alix]
        - [Gus]

  # ---------------------------------------------------------------------------
  # not() step combinations
  # ---------------------------------------------------------------------------

  - name: not_with_has_label
    query: "g.V().not(hasLabel('Company')).count()"
    expect:
      rows:
        - [3]

  - name: not_with_property_filter
    query: "g.V().hasLabel('Person').not(has('city', 'Berlin')).values('name')"
    expect:
      rows:
        - [Alix]
        - [Vincent]

  - name: not_with_navigation
    # not(out('WORKS_AT')) keeps vertices without outgoing WORKS_AT
    query: "g.V().hasLabel('Person').not(out('WORKS_AT')).values('name')"
    expect:
      rows:
        - [Gus]
        - [Vincent]

  # ---------------------------------------------------------------------------
  # where() with has() filter (not navigation)
  # ---------------------------------------------------------------------------

  - name: where_has_property
    query: "g.V().hasLabel('Person').where(has('age', gt(28))).values('name')"
    expect:
      rows:
        - [Alix]
        - [Vincent]

  - name: where_has_key
    query: "g.V().where(has('founded')).values('name')"
    expect:
      rows:
        - [Grafeo OSS]

  # ---------------------------------------------------------------------------
  # filter() step
  # ---------------------------------------------------------------------------

  - name: filter_by_property
    query: "g.V().hasLabel('Person').filter(has('age', gt(28))).count()"
    expect:
      rows:
        - [2]

  - name: filter_by_has_key
    query: "g.V().filter(has('founded')).count()"
    expect:
      rows:
        - [1]

  - name: filter_equivalent_to_where
    # filter(has('city', 'Amsterdam')) should produce same result as where(has('city', 'Amsterdam'))
    query: "g.V().filter(has('city', 'Amsterdam')).values('name')"
    expect:
      rows:
        - [Alix]

  # ---------------------------------------------------------------------------
  # coalesce() edge cases
  # ---------------------------------------------------------------------------

  - name: coalesce_fallback_only
    # Vincent has no outgoing KNOWS or WORKS_AT, falls back to values('name')
    query: "g.V().has('Person', 'name', 'Vincent').coalesce(out('KNOWS'), out('WORKS_AT'), values('name'))"
    expect:
      count: 1

  - name: coalesce_first_match_only
    skip: "coalesce still returns all branches instead of first non-empty"
    # Alix has out('KNOWS') (Gus) and out('WORKS_AT') (Grafeo OSS)
    # True coalesce should only return the first non-empty branch
    query: "g.V().has('Person', 'name', 'Alix').coalesce(out('KNOWS'), out('WORKS_AT')).count()"
    expect:
      rows:
        - [1]
