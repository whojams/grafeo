# Gremlin step edge cases: otherV(), label()/id() on edges, sideEffect()
#                        variants, where(P.predicate), chained aggregations
#                        after filters, count() after navigation, empty results,
#                        has() type variants, mixed label+property chains.
#
# Targets step variants with zero or thin test coverage.
#
# Social network topology (from dataset):
#   Persons: Alix(30, Amsterdam), Gus(25, Berlin), Vincent(35, Paris)
#   Company: Grafeo OSS (founded 2025)
#   Edges: Alix-KNOWS{since:2020}->Gus, Gus-KNOWS{since:2021}->Vincent,
#          Alix-WORKS_AT{role:'Engineer',since:2019}->Grafeo OSS

meta:
  language: gremlin
  model: lpg
  section: "step-edge-cases"
  title: Step Edge Cases
  dataset: social_network

tests:

  # ---------------------------------------------------------------------------
  # 1. otherV() - ZERO coverage in translator
  # ---------------------------------------------------------------------------

  - name: other_v_from_out_edge
    skip: "otherV() not implemented in translator"
    query: "g.V().has('Person', 'name', 'Alix').outE('KNOWS').otherV().values('name')"
    expect:
      rows:
        - [Gus]

  - name: other_v_from_in_edge
    skip: "otherV() not implemented in translator"
    query: "g.V().has('Person', 'name', 'Gus').inE('KNOWS').otherV().values('name')"
    expect:
      rows:
        - [Alix]

  - name: other_v_count
    skip: "otherV() not implemented in translator"
    query: "g.V().has('Person', 'name', 'Alix').outE().otherV().count()"
    expect:
      rows:
        - [2]

  # ---------------------------------------------------------------------------
  # 2. label() step on edges
  # ---------------------------------------------------------------------------

  - name: label_on_out_edges
    skip: "label() on edge variables returns null, Labels() not resolved for edges"
    query: "g.V().has('Person', 'name', 'Alix').outE().label()"
    expect:
      rows:
        - [KNOWS]
        - [WORKS_AT]

  - name: label_on_single_edge_type
    skip: "label() on edge variables returns null"
    query: "g.V().has('Person', 'name', 'Alix').outE('KNOWS').label()"
    expect:
      rows:
        - [KNOWS]

  - name: label_on_in_edge
    skip: "label() on edge variables returns null"
    query: "g.V().has('Person', 'name', 'Gus').inE('KNOWS').label()"
    expect:
      rows:
        - [KNOWS]

  # ---------------------------------------------------------------------------
  # 3. id() step on edges
  # ---------------------------------------------------------------------------

  - name: id_on_single_edge
    query: "g.V().has('Person', 'name', 'Alix').outE('KNOWS').id()"
    expect:
      count: 1

  - name: id_on_all_edges
    query: "g.E().id()"
    expect:
      count: 3

  - name: id_on_filtered_edges
    query: "g.V().has('Person', 'name', 'Alix').outE().id()"
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # 4. sideEffect() - expanded coverage
  # ---------------------------------------------------------------------------

  - name: side_effect_has_pass_through
    query: "g.V().hasLabel('Person').sideEffect(has('age')).count()"
    expect:
      rows:
        - [3]

  - name: side_effect_out_does_not_change_traverser
    query: "g.V().hasLabel('Person').sideEffect(out('KNOWS')).values('name')"
    expect:
      rows:
        - [Alix]
        - [Gus]
        - [Vincent]

  - name: side_effect_chained_still_counts_all
    query: "g.V().hasLabel('Person').sideEffect(has('age')).sideEffect(has('city')).count()"
    expect:
      rows:
        - [3]

  - name: side_effect_preserves_values
    query: "g.V().has('Person', 'name', 'Alix').sideEffect(out('KNOWS')).values('name')"
    expect:
      rows:
        - [Alix]

  # ---------------------------------------------------------------------------
  # 5. where() with P.predicate variant (WhereClause::Predicate)
  #    Syntax: where(P.gt(value)) - requires P. prefix
  # ---------------------------------------------------------------------------

  - name: where_predicate_gt
    query: "g.V().hasLabel('Person').values('age').where(P.gt(28))"
    expect:
      rows:
        - [30]
        - [35]

  - name: where_predicate_lt
    query: "g.V().hasLabel('Person').values('age').where(P.lt(30))"
    expect:
      rows:
        - [25]

  - name: where_predicate_eq
    query: "g.V().hasLabel('Person').values('age').where(P.eq(30))"
    expect:
      rows:
        - [30]

  - name: where_predicate_gte
    query: "g.V().hasLabel('Person').values('age').where(P.gte(30))"
    expect:
      rows:
        - [30]
        - [35]

  - name: where_predicate_neq
    query: "g.V().hasLabel('Person').values('age').where(P.neq(25))"
    expect:
      rows:
        - [30]
        - [35]

  # ---------------------------------------------------------------------------
  # 6. Chaining aggregations after filter
  # ---------------------------------------------------------------------------

  - name: sum_after_gt_filter
    query: "g.V().hasLabel('Person').has('age', gt(25)).values('age').sum()"
    expect:
      rows:
        - [65]

  - name: min_after_lt_filter
    query: "g.V().hasLabel('Person').has('age', lt(35)).values('age').min()"
    expect:
      rows:
        - [25]

  - name: max_after_gte_filter
    query: "g.V().hasLabel('Person').has('age', gte(25)).values('age').max()"
    expect:
      rows:
        - [35]

  - name: count_after_gt_filter
    query: "g.V().hasLabel('Person').has('age', gt(25)).count()"
    expect:
      rows:
        - [2]

  # ---------------------------------------------------------------------------
  # 7. count() after various navigation steps
  # ---------------------------------------------------------------------------

  - name: count_after_out_knows
    query: "g.V().hasLabel('Person').out('KNOWS').count()"
    expect:
      rows:
        - [2]

  - name: count_after_in_knows
    query: "g.V().hasLabel('Person').in('KNOWS').count()"
    expect:
      rows:
        - [2]

  - name: count_all_edges
    query: "g.E().count()"
    expect:
      rows:
        - [3]

  - name: count_after_out_all
    query: "g.V().hasLabel('Person').out().count()"
    expect:
      rows:
        - [3]

  - name: count_after_in_works_at
    query: "g.V().hasLabel('Company').in('WORKS_AT').count()"
    expect:
      rows:
        - [1]

  - name: count_after_two_hop
    query: "g.V().has('Person', 'name', 'Alix').out('KNOWS').out('KNOWS').count()"
    expect:
      rows:
        - [1]

  # ---------------------------------------------------------------------------
  # 8. Empty result handling
  # ---------------------------------------------------------------------------

  - name: empty_nonexistent_label
    query: "g.V().hasLabel('NonExistent').values('name')"
    expect:
      empty: true

  - name: empty_impossible_filter
    query: "g.V().has('age', gt(100))"
    expect:
      empty: true

  - name: empty_no_outgoing_edges
    query: "g.V().has('Person', 'name', 'Vincent').out('KNOWS')"
    expect:
      empty: true

  - name: empty_count_zero
    query: "g.V().has('Person', 'name', 'Vincent').out('KNOWS').count()"
    expect:
      rows:
        - [0]

  - name: empty_no_incoming_edges
    query: "g.V().has('Person', 'name', 'Alix').in('KNOWS')"
    expect:
      empty: true

  - name: empty_company_no_outgoing
    query: "g.V().has('Company', 'name', 'Grafeo OSS').out()"
    expect:
      empty: true

  - name: empty_values_on_missing_property
    skip: "values('nonexistent') returns null row instead of filtering to empty"
    query: "g.V().has('Person', 'name', 'Alix').values('nonexistent')"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # 9. has() with various value types
  # ---------------------------------------------------------------------------

  - name: has_with_string_value
    query: "g.V().has('name', 'Alix').values('age')"
    expect:
      rows:
        - [30]

  - name: has_with_integer_value
    query: "g.V().has('age', 30).values('name')"
    expect:
      rows:
        - [Alix]

  - name: has_neq_predicate_count
    query: "g.V().hasLabel('Person').has('age', neq(30)).count()"
    expect:
      rows:
        - [2]

  - name: has_neq_predicate_names
    query: "g.V().hasLabel('Person').has('age', neq(30)).values('name')"
    expect:
      rows:
        - [Gus]
        - [Vincent]

  - name: has_with_label_and_integer
    query: "g.V().has('Person', 'age', 25).values('name')"
    expect:
      rows:
        - [Gus]

  - name: has_key_only_existence
    query: "g.V().has('founded').values('name')"
    expect:
      rows:
        - [Grafeo OSS]

  # ---------------------------------------------------------------------------
  # 10. Mixed label + property chains
  # ---------------------------------------------------------------------------

  - name: label_city_age_chain
    query: "g.V().hasLabel('Person').has('city', 'Amsterdam').has('age', 30).values('name')"
    expect:
      rows:
        - [Alix]

  - name: range_filter_gte_lte
    query: "g.V().hasLabel('Person').has('age', gte(30)).has('age', lte(35)).count()"
    expect:
      rows:
        - [2]

  - name: range_filter_gte_lte_names
    query: "g.V().hasLabel('Person').has('age', gte(30)).has('age', lte(35)).values('name')"
    expect:
      rows:
        - [Alix]
        - [Vincent]

  - name: label_and_multiple_property_filters
    query: "g.V().hasLabel('Person').has('city', 'Berlin').has('age', 25).values('name')"
    expect:
      rows:
        - [Gus]

  - name: label_chain_no_match
    query: "g.V().hasLabel('Person').has('city', 'Amsterdam').has('age', 25)"
    expect:
      empty: true

  - name: label_with_edge_filter_chain
    query: "g.V().hasLabel('Person').has('age', gte(30)).out('KNOWS').values('name')"
    expect:
      rows:
        - [Gus]
