# Common: NULL semantics
#
# Covers: NULL comparisons, NULL propagation in expressions,
# NULL in aggregation, IS NULL / IS NOT NULL predicates.
# These are data-model-agnostic and apply to all LPG languages.

meta:
  language: gql
  model: lpg
  section: null
  title: NULL semantics
  dataset: empty

tests:

  # ---------------------------------------------------------------------------
  # NULL comparisons (three-valued logic)
  # ---------------------------------------------------------------------------

  - name: null_equals_null_is_null
    query: RETURN null = null AS result
    expect:
      rows:
        - [null]

  - name: null_not_equals_null_is_null
    query: RETURN null <> null AS result
    expect:
      rows:
        - [null]

  - name: null_greater_than_value_is_null
    query: RETURN null > 5 AS result
    expect:
      rows:
        - [null]

  - name: null_and_true_is_null
    query: RETURN null AND true AS result
    expect:
      rows:
        - [null]

  - name: null_and_false_is_false
    query: RETURN null AND false AS result
    expect:
      rows:
        - [false]

  - name: null_or_true_is_true
    query: RETURN null OR true AS result
    expect:
      rows:
        - [true]

  - name: null_or_false_is_null
    query: RETURN null OR false AS result
    expect:
      rows:
        - [null]

  - name: not_null_is_null
    query: RETURN NOT null AS result
    expect:
      rows:
        - [null]

  # ---------------------------------------------------------------------------
  # IS NULL / IS NOT NULL
  # ---------------------------------------------------------------------------

  - name: is_null_on_missing_property
    setup:
      - "INSERT (:Person {name: 'Alix'})"
    query: MATCH (n:Person) WHERE n.email IS NULL RETURN n.name
    expect:
      rows:
        - [Alix]

  - name: is_not_null_on_existing_property
    setup:
      - "INSERT (:Person {name: 'Alix', email: 'alix@example.com'})"
      - "INSERT (:Person {name: 'Gus'})"
    query: MATCH (n:Person) WHERE n.email IS NOT NULL RETURN n.name
    expect:
      rows:
        - [Alix]

  # ---------------------------------------------------------------------------
  # NULL propagation in expressions
  # ---------------------------------------------------------------------------

  - name: null_plus_number_is_null
    query: RETURN null + 5 AS result
    expect:
      rows:
        - [null]

  - name: null_in_string_concat_is_null
    query: "RETURN 'hello' + null AS result"
    expect:
      rows:
        - [null]

  - name: coalesce_returns_first_non_null
    query: RETURN coalesce(null, null, 42) AS result
    expect:
      rows:
        - [42]

  - name: coalesce_all_null_returns_null
    query: RETURN coalesce(null, null) AS result
    expect:
      rows:
        - [null]

  # ---------------------------------------------------------------------------
  # NULL in aggregation
  # ---------------------------------------------------------------------------

  - name: count_excludes_null
    setup:
      - "INSERT (:Item {val: 1})"
      - "INSERT (:Item {val: 2})"
      - "INSERT (:Item {})"
    query: MATCH (i:Item) RETURN count(i.val) AS cnt
    expect:
      rows:
        - [2]

  - name: count_star_includes_null_rows
    setup:
      - "INSERT (:Item {val: 1})"
      - "INSERT (:Item {val: 2})"
      - "INSERT (:Item {})"
    query: MATCH (i:Item) RETURN count(*) AS cnt
    expect:
      rows:
        - [3]

  - name: sum_ignores_null
    setup:
      - "INSERT (:Item {val: 10})"
      - "INSERT (:Item {val: 20})"
      - "INSERT (:Item {})"
    query: MATCH (i:Item) RETURN sum(i.val) AS total
    expect:
      rows:
        - [30]

  - name: optional_match_null_in_aggregation
    setup:
      - "INSERT (:Person {name: 'Alix'})"
      - "INSERT (:Person {name: 'Gus'})"
    query: |
      MATCH (p:Person)
      OPTIONAL MATCH (p)-[:KNOWS]->(friend)
      RETURN p.name, count(friend) AS friend_count
    expect:
      rows:
        - [Alix, 0]
        - [Gus, 0]

  # ---------------------------------------------------------------------------
  # NULL equality in WHERE (three-valued logic filters)
  # ---------------------------------------------------------------------------

  - name: null_equality_in_where_filters_out
    setup:
      - "INSERT (:Item {name: 'alpha', val: 10})"
      - "INSERT (:Item {name: 'beta'})"
      - "INSERT (:Item {name: 'gamma', val: 30})"
    query: "MATCH (i:Item) WHERE i.val = NULL RETURN i.name AS name ORDER BY name"
    expect:
      empty: true

  - name: null_ne_null_in_where_filters_out
    setup:
      - "INSERT (:Item {name: 'alpha', val: 10})"
      - "INSERT (:Item {name: 'beta'})"
      - "INSERT (:Item {name: 'gamma', val: 30})"
    query: "MATCH (i:Item) WHERE i.val <> NULL RETURN i.name AS name ORDER BY name"
    expect:
      empty: true

  - name: null_gt_in_where_filters_out
    setup:
      - "INSERT (:Item {name: 'alpha', val: 10})"
      - "INSERT (:Item {name: 'beta'})"
      - "INSERT (:Item {name: 'gamma', val: 30})"
    query: MATCH (i:Item) WHERE i.val > NULL RETURN i.name
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # NULL in CASE expressions
  # ---------------------------------------------------------------------------

  - name: case_when_null_eq_null_is_unknown
    setup:
      - "INSERT (:Item {name: 'beta'})"
    query: "MATCH (i:Item) WHERE i.name = 'beta' RETURN CASE WHEN i.val = NULL THEN 'hit' ELSE 'miss' END AS result"
    expect:
      rows:
        - [miss]

  - name: simple_case_null_when_null
    setup:
      - "INSERT (:Item {name: 'beta'})"
    query: "MATCH (i:Item) WHERE i.name = 'beta' RETURN CASE i.val WHEN NULL THEN 'hit' ELSE 'miss' END AS result"
    expect:
      rows:
        - [miss]

  - name: case_when_is_not_null_goes_to_else
    setup:
      - "INSERT (:Item {name: 'beta'})"
    query: "MATCH (i:Item) WHERE i.name = 'beta' RETURN CASE WHEN i.val IS NOT NULL THEN 'has_val' ELSE 'no_val' END AS status"
    expect:
      rows:
        - [no_val]

  - name: simple_case_matching_value
    setup:
      - "INSERT (:X {v: 1})"
    query: "MATCH (x:X) RETURN CASE x.v WHEN 1 THEN 'one' WHEN 2 THEN 'two' ELSE 'other' END AS label"
    expect:
      rows:
        - [one]

  # ---------------------------------------------------------------------------
  # Boolean logic with UNKNOWN (NULL in WHERE)
  # ---------------------------------------------------------------------------

  - name: or_with_unknown_true_passes
    setup:
      - "INSERT (:Item {name: 'alpha', val: 10})"
      - "INSERT (:Item {name: 'beta'})"
      - "INSERT (:Item {name: 'gamma', val: 30})"
    query: "MATCH (i:Item) WHERE i.val = NULL OR i.name = 'alpha' RETURN i.name AS name ORDER BY name"
    expect:
      rows:
        - [alpha]

  - name: and_with_unknown_filters_out
    setup:
      - "INSERT (:Item {name: 'alpha', val: 10})"
      - "INSERT (:Item {name: 'beta'})"
      - "INSERT (:Item {name: 'gamma', val: 30})"
    query: "MATCH (i:Item) WHERE i.val = NULL AND i.name = 'beta' RETURN i.name AS name"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # NULLIF edge cases
  # ---------------------------------------------------------------------------

  - name: nullif_both_null
    query: RETURN NULLIF(NULL, NULL) AS result
    expect:
      rows:
        - [null]

  - name: nullif_value_with_null
    query: RETURN NULLIF(42, NULL) AS result
    expect:
      rows:
        - [42]

  # ---------------------------------------------------------------------------
  # Missing property access
  # ---------------------------------------------------------------------------

  - name: missing_property_returns_null
    setup:
      - "INSERT (:Thing {name: 'only_name'})"
    query: MATCH (t:Thing) RETURN t.nonexistent AS val
    expect:
      rows:
        - [null]

  # ---------------------------------------------------------------------------
  # Aggregation with NULLs (sum, avg, min, max, count)
  # ---------------------------------------------------------------------------

  - name: sum_skips_nulls
    setup:
      - "INSERT (:Item {name: 'alpha', val: 10})"
      - "INSERT (:Item {name: 'beta'})"
      - "INSERT (:Item {name: 'gamma', val: 30})"
    query: MATCH (i:Item) RETURN sum(i.val) AS total
    expect:
      rows:
        - [40]

  - name: avg_skips_nulls
    setup:
      - "INSERT (:Item {name: 'alpha', val: 10})"
      - "INSERT (:Item {name: 'beta'})"
      - "INSERT (:Item {name: 'gamma', val: 30})"
    query: MATCH (i:Item) RETURN avg(i.val) AS average
    expect:
      rows:
        - [20]

  - name: min_max_skip_nulls
    setup:
      - "INSERT (:Item {name: 'alpha', val: 10})"
      - "INSERT (:Item {name: 'beta'})"
      - "INSERT (:Item {name: 'gamma', val: 30})"
    query: MATCH (i:Item) RETURN min(i.val) AS lo, max(i.val) AS hi
    expect:
      rows:
        - [10, 30]

  - name: count_expr_vs_count_node
    setup:
      - "INSERT (:Item {name: 'alpha', val: 10})"
      - "INSERT (:Item {name: 'beta'})"
      - "INSERT (:Item {name: 'gamma', val: 30})"
    query: MATCH (i:Item) RETURN count(i.val) AS cnt, count(i) AS total
    expect:
      rows:
        - [2, 3]

  # ---------------------------------------------------------------------------
  # IN operator with NULL in list
  # ---------------------------------------------------------------------------

  - name: in_list_with_null
    setup:
      - "INSERT (:N {v: 1})"
      - "INSERT (:N {v: 2})"
      - "INSERT (:N {v: 5})"
    query: "MATCH (n:N) WHERE n.v IN [1, NULL, 5] RETURN n.v AS v ORDER BY v"
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # NULL arithmetic propagation
  # ---------------------------------------------------------------------------

  - name: null_property_plus_one_is_null
    setup:
      - "INSERT (:Item {name: 'beta'})"
    query: "MATCH (i:Item) WHERE i.name = 'beta' RETURN i.val + 1 AS incremented"
    expect:
      rows:
        - [null]

  # ---------------------------------------------------------------------------
  # DISTINCT with NULLs
  # ---------------------------------------------------------------------------

  - name: distinct_deduplicates_nulls
    setup:
      - "INSERT (:D {v: 1})"
      - "INSERT (:D {v: 1})"
      - "INSERT (:D {})"
      - "INSERT (:D {})"
      - "INSERT (:D {v: 2})"
    query: MATCH (d:D) RETURN DISTINCT d.v AS v ORDER BY v
    expect:
      count: 3

  # ---------------------------------------------------------------------------
  # GROUP BY with NULL keys
  # ---------------------------------------------------------------------------

  - name: group_by_null_key
    setup:
      - "INSERT (:Sale {region: 'North', amount: 100})"
      - "INSERT (:Sale {amount: 50})"
      - "INSERT (:Sale {region: 'North', amount: 200})"
      - "INSERT (:Sale {amount: 75})"
    query: "MATCH (s:Sale) RETURN s.region AS region, sum(s.amount) AS total ORDER BY region"
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # NULL in inline property patterns (MATCH and MERGE)
  # ---------------------------------------------------------------------------

  - name: match_null_property_pattern_matches_absent
    setup:
      - "INSERT (:Rec {id: 'r1', b: 'x'})"
    query: "MATCH (n:Rec {id: null, b: 'x'}) RETURN n.b AS b"
    expect:
      empty: true
    note: "id exists and is 'r1', not null, so no match"

  - name: match_null_property_pattern_matches_null_value
    setup:
      - "INSERT (:Rec {id: null, b: 'x'})"
    query: "MATCH (n:Rec {id: null, b: 'x'}) RETURN n.b AS b"
    expect:
      rows:
        - [x]

  - name: match_null_property_pattern_matches_missing_key
    setup:
      - "INSERT (:Rec {b: 'x'})"
    query: "MATCH (n:Rec {id: null, b: 'x'}) RETURN n.b AS b"
    expect:
      rows:
        - [x]

  - name: merge_with_null_key_creates_then_matches
    statements:
      - "MERGE (n:Composite {a: null, b: 'x'}) SET n.c = 1"
      - "MERGE (n:Composite {a: null, b: 'x'}) SET n.c = 2"
      - "MATCH (n:Composite) RETURN n.b AS b, n.c AS c"
    expect:
      rows:
        - [x, 2]

  - name: merge_null_key_does_not_match_non_null
    statements:
      - "INSERT (:MergeNull {a: 'real', b: 'y'})"
      - "MERGE (n:MergeNull {a: null, b: 'y'}) SET n.c = 99"
      - "MATCH (n:MergeNull) RETURN n.a AS a, n.b AS b, n.c AS c ORDER BY a"
    expect:
      rows:
        - [null, y, 99]
        - [real, y, null]

  # ---------------------------------------------------------------------------
  # SET += {key: null} removes property
  # ---------------------------------------------------------------------------

  - name: set_plus_equals_null_removes_node_property
    # SET n += {key: null} must remove the property, not store null
    statements:
      - "INSERT (:SetNull {name: 'Alix', price: 42})"
      - "MATCH (n:SetNull) SET n += {price: null}"
      - "MATCH (n:SetNull) RETURN n.name AS name, n.price AS price"
    expect:
      rows:
        - [Alix, null]

  - name: set_plus_equals_null_preserves_other_properties
    # Only the null-valued key is removed; others from the map are set normally
    statements:
      - "INSERT (:SetMix {a: 1, b: 2, c: 3})"
      - "MATCH (n:SetMix) SET n += {b: null, c: 99, d: 'new'}"
      - "MATCH (n:SetMix) RETURN n.a AS a, n.b AS b, n.c AS c, n.d AS d"
    expect:
      rows:
        - [1, null, 99, new]

  - name: set_plus_equals_null_removes_edge_property
    statements:
      - "INSERT (:EP {name: 'a'})-[:R {weight: 5, tag: 'x'}]->(:EP {name: 'b'})"
      - "MATCH (:EP)-[r:R]->(:EP) SET r += {weight: null}"
      - "MATCH (:EP)-[r:R]->(:EP) RETURN r.weight AS w, r.tag AS t"
    expect:
      rows:
        - [null, x]

  - name: set_plus_equals_all_null_clears_all
    # Map with all null values removes all listed properties
    statements:
      - "INSERT (:ClearAll {x: 1, y: 2})"
      - "MATCH (n:ClearAll) SET n += {x: null, y: null}"
      - "MATCH (n:ClearAll) RETURN n.x AS x, n.y AS y"
    expect:
      rows:
        - [null, null]

  - name: negative_limit_returns_empty
    setup:
      - "INSERT (:LimTest {v: 1})"
      - "INSERT (:LimTest {v: 2})"
    query: "MATCH (n:LimTest) RETURN n.v AS v LIMIT -1"
    expect:
      empty: true

  - name: negative_limit_returns_empty_cypher
    setup:
      - "INSERT (:LimTest2 {v: 1})"
      - "INSERT (:LimTest2 {v: 2})"
    variants:
      cypher: "MATCH (n:LimTest2) RETURN n.v AS v LIMIT -1"
    expect:
      empty: true
