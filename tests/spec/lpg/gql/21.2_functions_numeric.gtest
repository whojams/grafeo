# GQL Numeric Functions: ISO/IEC 39075:2024 sec 21.2

meta:
  language: gql
  model: lpg
  section: "21.2"
  title: Numeric functions
  dataset: empty

tests:

  - name: abs_negative
    setup:
      - "INSERT (:N {v: -5})"
    query: MATCH (n:N) RETURN abs(n.v) AS r
    expect:
      rows:
        - [5]

  - name: ceil_float
    setup:
      - "INSERT (:N {v: 3.2})"
    query: MATCH (n:N) RETURN ceil(n.v) AS r
    expect:
      count: 1

  - name: floor_float
    setup:
      - "INSERT (:N {v: 3.8})"
    query: MATCH (n:N) RETURN floor(n.v) AS r
    expect:
      count: 1

  - name: round_half_up
    setup:
      - "INSERT (:N {v: 3.5})"
    query: MATCH (n:N) RETURN round(n.v) AS r
    expect:
      count: 1

  - name: sqrt_perfect_square
    setup:
      - "INSERT (:N {v: 16})"
    query: MATCH (n:N) RETURN sqrt(n.v) AS r
    expect:
      count: 1

  - name: sign_negative
    setup:
      - "INSERT (:N {v: -5})"
    query: MATCH (n:N) RETURN sign(n.v) AS r
    expect:
      rows:
        - [-1]

  - name: sign_positive
    setup:
      - "INSERT (:N {v: 5})"
    query: MATCH (n:N) RETURN sign(n.v) AS r
    expect:
      rows:
        - [1]

  - name: sign_zero
    setup:
      - "INSERT (:N {v: 0})"
    query: MATCH (n:N) RETURN sign(n.v) AS r
    expect:
      rows:
        - [0]

  - name: exp_of_zero
    setup:
      - "INSERT (:N {v: 0})"
    query: MATCH (n:N) RETURN exp(n.v) AS r
    expect:
      count: 1

  - name: pi_constant
    query: RETURN pi() AS r
    expect:
      count: 1

  - name: e_constant
    query: RETURN e() AS r
    expect:
      count: 1

  - name: rand_returns_value
    query: RETURN rand() AS r
    expect:
      count: 1

  # ---------------------------------------------------------------------------
  # Trigonometric functions (ISO/IEC 39075:2024 Section 21.2)
  # ---------------------------------------------------------------------------

  - name: sin_returns_result
    query: RETURN sin(1.5) AS r
    expect:
      count: 1

  - name: cos_returns_result
    query: RETURN cos(1.5) AS r
    expect:
      count: 1

  - name: tan_returns_result
    query: RETURN tan(0.5) AS r
    expect:
      count: 1

  - name: asin_returns_result
    query: RETURN asin(0.5) AS r
    expect:
      count: 1

  - name: acos_returns_result
    query: RETURN acos(0.5) AS r
    expect:
      count: 1

  - name: atan_returns_result
    query: RETURN atan(1.0) AS r
    expect:
      count: 1

  - name: atan2_returns_result
    query: RETURN atan2(1.0, 1.0) AS r
    expect:
      count: 1

  - name: degrees_returns_result
    query: RETURN degrees(1.5) AS r
    expect:
      count: 1

  - name: radians_returns_result
    query: RETURN radians(90.0) AS r
    expect:
      count: 1

  # ---------------------------------------------------------------------------
  # Logarithmic functions
  # ---------------------------------------------------------------------------

  - name: log10_returns_result
    query: RETURN log10(100.0) AS r
    expect:
      count: 1

  - name: log2_returns_result
    query: RETURN log2(8.0) AS r
    expect:
      count: 1

  # ---------------------------------------------------------------------------
  # Power / exponentiation
  # ---------------------------------------------------------------------------

  - name: power_returns_result
    query: RETURN 2.0 ^ 10.0 AS r
    expect:
      count: 1

  - name: power_square_root
    query: RETURN 9.0 ^ 0.5 AS r
    expect:
      count: 1
