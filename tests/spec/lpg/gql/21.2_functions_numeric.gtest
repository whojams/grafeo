# GQL Numeric Functions: ISO/IEC 39075:2024 sec 21.2

meta:
  language: gql
  model: lpg
  section: "21.2"
  title: Numeric functions
  dataset: empty

tests:

  - name: abs_negative
    setup:
      - "INSERT (:N {v: -5})"
    query: MATCH (n:N) RETURN abs(n.v) AS r
    expect:
      rows:
        - [5]

  - name: ceil_float
    setup:
      - "INSERT (:N {v: 3.2})"
    query: MATCH (n:N) RETURN ceil(n.v) AS r
    expect:
      count: 1

  - name: floor_float
    setup:
      - "INSERT (:N {v: 3.8})"
    query: MATCH (n:N) RETURN floor(n.v) AS r
    expect:
      count: 1

  - name: round_half_up
    setup:
      - "INSERT (:N {v: 3.5})"
    query: MATCH (n:N) RETURN round(n.v) AS r
    expect:
      count: 1

  - name: sqrt_perfect_square
    setup:
      - "INSERT (:N {v: 16})"
    query: MATCH (n:N) RETURN sqrt(n.v) AS r
    expect:
      count: 1

  - name: sign_negative
    setup:
      - "INSERT (:N {v: -5})"
    query: MATCH (n:N) RETURN sign(n.v) AS r
    expect:
      rows:
        - [-1]

  - name: sign_positive
    setup:
      - "INSERT (:N {v: 5})"
    query: MATCH (n:N) RETURN sign(n.v) AS r
    expect:
      rows:
        - [1]

  - name: sign_zero
    setup:
      - "INSERT (:N {v: 0})"
    query: MATCH (n:N) RETURN sign(n.v) AS r
    expect:
      rows:
        - [0]

  - name: exp_of_zero
    setup:
      - "INSERT (:N {v: 0})"
    query: MATCH (n:N) RETURN exp(n.v) AS r
    expect:
      count: 1

  - name: pi_constant
    query: RETURN pi() AS r
    expect:
      count: 1

  - name: e_constant
    query: RETURN e() AS r
    expect:
      count: 1

  - name: rand_returns_value
    query: RETURN rand() AS r
    expect:
      count: 1
