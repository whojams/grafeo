# Gremlin navigation steps: out(), in(), both(), outE(), inE(), bothE(), outV(), inV()
#
# Covers: vertex-to-vertex, vertex-to-edge, and edge-to-vertex traversals.
#
# Social network topology (from dataset):
#   Alix -[KNOWS {since:2020}]-> Gus
#   Gus  -[KNOWS {since:2021}]-> Vincent
#   Alix -[WORKS_AT {role:'Engineer', since:2019}]-> Grafeo OSS

meta:
  language: gremlin
  model: lpg
  section: "navigation"
  title: Navigation Steps
  dataset: social_network

tests:

  # ---------------------------------------------------------------------------
  # out() - outgoing vertex traversal
  # ---------------------------------------------------------------------------

  - name: out_labeled
    query: "g.V().has('Person', 'name', 'Alix').out('KNOWS').values('name')"
    expect:
      rows:
        - [Gus]

  - name: out_unlabeled
    query: "g.V().has('Person', 'name', 'Alix').out()"
    expect:
      count: 2

  - name: out_no_results
    query: "g.V().has('Person', 'name', 'Vincent').out('KNOWS')"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # in() - incoming vertex traversal
  # ---------------------------------------------------------------------------

  - name: in_labeled
    query: "g.V().has('Person', 'name', 'Gus').in('KNOWS').values('name')"
    expect:
      rows:
        - [Alix]

  - name: in_unlabeled
    query: "g.V().has('Person', 'name', 'Gus').in()"
    expect:
      count: 1

  - name: in_company
    query: "g.V().has('Company', 'name', 'Grafeo OSS').in('WORKS_AT').values('name')"
    expect:
      rows:
        - [Alix]

  # ---------------------------------------------------------------------------
  # both() - bidirectional vertex traversal
  # ---------------------------------------------------------------------------

  - name: both_labeled
    query: "g.V().has('Person', 'name', 'Gus').both('KNOWS')"
    expect:
      count: 2

  - name: both_unlabeled
    query: "g.V().has('Person', 'name', 'Alix').both()"
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # outE() - outgoing edge traversal
  # ---------------------------------------------------------------------------

  - name: out_e_labeled
    query: "g.V().has('Person', 'name', 'Alix').outE('KNOWS')"
    expect:
      count: 1

  - name: out_e_all
    query: "g.V().has('Person', 'name', 'Alix').outE()"
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # inE() - incoming edge traversal
  # ---------------------------------------------------------------------------

  - name: in_e_labeled
    query: "g.V().has('Person', 'name', 'Gus').inE('KNOWS')"
    expect:
      count: 1

  - name: in_e_all
    query: "g.V().has('Person', 'name', 'Gus').inE()"
    expect:
      count: 1

  # ---------------------------------------------------------------------------
  # bothE() - bidirectional edge traversal
  # ---------------------------------------------------------------------------

  - name: both_e_labeled
    query: "g.V().has('Person', 'name', 'Gus').bothE('KNOWS')"
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # outV() - edge-to-source vertex
  # ---------------------------------------------------------------------------

  - name: out_v
    query: "g.V().has('Person', 'name', 'Alix').outE('KNOWS').outV().values('name')"
    expect:
      rows:
        - [Alix]

  # ---------------------------------------------------------------------------
  # inV() - edge-to-target vertex
  # ---------------------------------------------------------------------------

  - name: in_v
    query: "g.V().has('Person', 'name', 'Alix').outE('KNOWS').inV().values('name')"
    expect:
      rows:
        - [Gus]

  # ---------------------------------------------------------------------------
  # Multi-hop traversal
  # ---------------------------------------------------------------------------

  - name: two_hop
    query: "g.V().has('Person', 'name', 'Alix').out('KNOWS').out('KNOWS').values('name')"
    expect:
      rows:
        - [Vincent]
