# GQL Transportation Real-World Queries
#
# Covers: shortest path, weighted traversals, connectivity analysis,
# route planning, geographic queries on a transportation network.
# Uses transportation dataset.

meta:
  language: gql
  model: lpg
  section: "22.4"
  title: Transportation real-world queries
  dataset: transportation

tests:

  # ---------------------------------------------------------------------------
  # Basic connectivity
  # ---------------------------------------------------------------------------

  - name: direct_routes_from_amsterdam
    query: |
      MATCH (a:City {name: 'Amsterdam'})-[r:ROUTE]->(b:City)
      RETURN b.name, r.distance_km, r.mode
      ORDER BY r.distance_km
    expect:
      ordered: true
      rows:
        - [Brussels, 210, train]
        - [Paris, 500, train]
        - [Berlin, 660, train]
        - [Barcelona, 1540, flight]

  - name: cities_reachable_by_train
    query: |
      MATCH (a:City {name: 'Amsterdam'})-[r:ROUTE]->(b:City)
      WHERE r.mode = 'train'
      RETURN b.name ORDER BY b.name
    expect:
      ordered: true
      rows:
        - [Berlin]
        - [Brussels]
        - [Paris]

  - name: bidirectional_routes
    query: |
      MATCH (a:City)-[r:ROUTE]->(b:City)
      WHERE a.name < b.name
      RETURN a.name, b.name, r.distance_km, r.mode
      ORDER BY r.distance_km
    expect:
      ordered: true
      count: 7

  # ---------------------------------------------------------------------------
  # Route analysis
  # ---------------------------------------------------------------------------

  - name: shortest_distance_amsterdam_to_prague
    query: |
      MATCH (a:City {name: 'Amsterdam'})-[r:ROUTE]->(b:City)-[r2:ROUTE]->(c:City {name: 'Prague'})
      RETURN a.name, b.name, c.name, r.distance_km + r2.distance_km AS total_km
      ORDER BY total_km
    expect:
      ordered: true
      count: 1

  - name: fastest_route_amsterdam_barcelona
    query: |
      MATCH (a:City {name: 'Amsterdam'})-[r:ROUTE]->(b:City {name: 'Barcelona'})
      RETURN r.mode, r.duration_h
      ORDER BY r.duration_h
    expect:
      ordered: true
      count: 1

  - name: two_hop_routes_amsterdam_barcelona
    skip: "two-hop route count mismatch"
    query: |
      MATCH (a:City {name: 'Amsterdam'})-[r1:ROUTE]->(mid:City)-[r2:ROUTE]->(b:City {name: 'Barcelona'})
      RETURN mid.name, r1.duration_h + r2.duration_h AS total_hours, r1.distance_km + r2.distance_km AS total_km
      ORDER BY total_hours
    expect:
      ordered: true
      count: 2

  # ---------------------------------------------------------------------------
  # Network analysis
  # ---------------------------------------------------------------------------

  - name: cities_with_most_connections
    query: |
      MATCH (c:City)-[r:ROUTE]->(:City)
      RETURN c.name, count(r) AS outgoing_routes
      ORDER BY outgoing_routes DESC, c.name
    expect:
      ordered: true
      rows:
        - [Amsterdam, 4]
        - [Paris, 3]
        - [Barcelona, 2]
        - [Berlin, 2]
        - [Brussels, 2]
        - [Prague, 1]

  - name: total_route_distance_from_city
    query: |
      MATCH (c:City)-[r:ROUTE]->(:City)
      RETURN c.name, sum(r.distance_km) AS total_km
      ORDER BY total_km DESC
    expect:
      ordered: true
      count: 6

  - name: avg_route_distance
    query: |
      MATCH (:City)-[r:ROUTE]->(:City)
      RETURN avg(r.distance_km) AS avg_km
    expect:
      precision: 0
      count: 1

  # ---------------------------------------------------------------------------
  # Cities with airports
  # ---------------------------------------------------------------------------

  - name: cities_with_airports
    query: |
      MATCH (c:City)-[:HAS_AIRPORT]->(a:Airport)
      RETURN c.name, a.code, a.name ORDER BY c.name
    expect:
      ordered: true
      rows:
        - [Amsterdam, AMS, Schiphol]
        - [Berlin, TXL, Berlin Brandenburg]
        - [Paris, CDG, Charles de Gaulle]

  - name: cities_without_airports
    query: |
      MATCH (c:City)
      WHERE NOT EXISTS { MATCH (c)-[:HAS_AIRPORT]->(:Airport) }
      RETURN c.name ORDER BY c.name
    expect:
      ordered: true
      rows:
        - [Barcelona]
        - [Brussels]
        - [Prague]

  # ---------------------------------------------------------------------------
  # Variable-length paths
  # ---------------------------------------------------------------------------

  - name: reachable_within_two_hops_train
    skip: "variable-length path dedup count"
    query: |
      MATCH (a:City {name: 'Amsterdam'})-[:ROUTE]->{1,2}(b:City)
      RETURN DISTINCT b.name ORDER BY b.name
    expect:
      ordered: true
      count: 5

  - name: all_paths_amsterdam_to_barcelona
    skip: "variable-length path enumeration"
    query: |
      MATCH p = (a:City {name: 'Amsterdam'})-[:ROUTE]->{1,3}(b:City {name: 'Barcelona'})
      RETURN length(p) AS hops
      ORDER BY hops
    expect:
      ordered: true
      count: 3

  # ---------------------------------------------------------------------------
  # Population analysis
  # ---------------------------------------------------------------------------

  - name: largest_cities
    query: |
      MATCH (c:City)
      RETURN c.name, c.population
      ORDER BY c.population DESC
      LIMIT 3
    expect:
      ordered: true
      rows:
        - [Berlin, 3748148]
        - [Paris, 2161000]
        - [Barcelona, 1636762]

  - name: cities_by_country
    query: |
      MATCH (c:City)
      RETURN c.country, count(c) AS city_count
      ORDER BY c.country
    expect:
      ordered: true
      rows:
        - [Belgium, 1]
        - [Czechia, 1]
        - [France, 1]
        - [Germany, 1]
        - [Netherlands, 1]
        - [Spain, 1]

  # ---------------------------------------------------------------------------
  # Route mode analysis
  # ---------------------------------------------------------------------------

  - name: routes_by_mode
    query: |
      MATCH (:City)-[r:ROUTE]->(:City)
      RETURN r.mode, count(r) AS cnt, avg(r.distance_km) AS avg_km
      ORDER BY r.mode
    expect:
      ordered: true
      precision: 0
      count: 2

  - name: fastest_mode_per_route
    query: |
      MATCH (a:City {name: 'Amsterdam'})-[r:ROUTE]->(b:City)
      RETURN b.name, r.mode, r.duration_h
      ORDER BY r.duration_h
      LIMIT 3
    expect:
      ordered: true
      count: 3
