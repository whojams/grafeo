# GQL Path Patterns: ISO/IEC 39075:2024 sec 17.1
#
# Covers: variable-length paths (*min..max, *exact, unbounded *),
# multi-label matching, WHERE label predicates, undirected edges,
# edge property filters, path length function, wildcard edges.

meta:
  language: gql
  model: lpg
  section: "17.1"
  title: Path patterns
  dataset: empty

tests:

  # ---------------------------------------------------------------------------
  # Variable-length paths
  # ---------------------------------------------------------------------------

  - name: variable_length_1_to_3
    setup:
      - "INSERT (:Node {name: 'A'})"
      - "INSERT (:Node {name: 'B'})"
      - "INSERT (:Node {name: 'C'})"
      - "INSERT (:Node {name: 'D'})"
      - "INSERT (:Node:Special {name: 'E'})"
      - "MATCH (a:Node {name: 'A'}), (b:Node {name: 'B'}) INSERT (a)-[:LINK]->(b)"
      - "MATCH (b:Node {name: 'B'}), (c:Node {name: 'C'}) INSERT (b)-[:LINK]->(c)"
      - "MATCH (c:Node {name: 'C'}), (d:Node {name: 'D'}) INSERT (c)-[:LINK]->(d)"
      - "MATCH (d:Node {name: 'D'}), (e:Node {name: 'E'}) INSERT (d)-[:LINK]->(e)"
      - "MATCH (a:Node {name: 'A'}), (c:Node {name: 'C'}) INSERT (a)-[:SHORTCUT]->(c)"
    query: "MATCH (a:Node {name: 'A'})-[:LINK *1..3]->(b:Node) RETURN b.name AS name ORDER BY name"
    expect:
      ordered: true
      rows:
        - [B]
        - [C]
        - [D]

  - name: variable_length_exact_2
    setup:
      - "INSERT (:Node {name: 'A'})"
      - "INSERT (:Node {name: 'B'})"
      - "INSERT (:Node {name: 'C'})"
      - "MATCH (a:Node {name: 'A'}), (b:Node {name: 'B'}) INSERT (a)-[:LINK]->(b)"
      - "MATCH (b:Node {name: 'B'}), (c:Node {name: 'C'}) INSERT (b)-[:LINK]->(c)"
    query: "MATCH (a:Node {name: 'A'})-[:LINK *2..2]->(b:Node) RETURN b.name AS name"
    expect:
      rows:
        - [C]

  - name: variable_length_unbounded
    setup:
      - "INSERT (:Node {name: 'A'})"
      - "INSERT (:Node {name: 'B'})"
      - "INSERT (:Node {name: 'C'})"
      - "INSERT (:Node {name: 'D'})"
      - "INSERT (:Node {name: 'E'})"
      - "MATCH (a:Node {name: 'A'}), (b:Node {name: 'B'}) INSERT (a)-[:LINK]->(b)"
      - "MATCH (b:Node {name: 'B'}), (c:Node {name: 'C'}) INSERT (b)-[:LINK]->(c)"
      - "MATCH (c:Node {name: 'C'}), (d:Node {name: 'D'}) INSERT (c)-[:LINK]->(d)"
      - "MATCH (d:Node {name: 'D'}), (e:Node {name: 'E'}) INSERT (d)-[:LINK]->(e)"
    query: "MATCH (a:Node {name: 'A'})-[:LINK*]->(b:Node) RETURN b.name AS name ORDER BY name"
    expect:
      ordered: true
      rows:
        - [B]
        - [C]
        - [D]
        - [E]

  # ---------------------------------------------------------------------------
  # Multi-label matching
  # ---------------------------------------------------------------------------

  - name: multi_label_and_semantics
    setup:
      - "INSERT (:Node {name: 'A'})"
      - "INSERT (:Node {name: 'B'})"
      - "INSERT (:Node:Special {name: 'C'})"
    query: MATCH (n:Node:Special) RETURN n.name AS name
    expect:
      rows:
        - [C]

  - name: multi_label_no_match_missing_label
    setup:
      - "INSERT (:Node:Special {name: 'A'})"
    query: MATCH (n:Special:Nonexistent) RETURN n.name AS name
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # WHERE label predicates
  # ---------------------------------------------------------------------------

  - name: where_label_predicate
    setup:
      - "INSERT (:Node {name: 'A'})"
      - "INSERT (:Node {name: 'B'})"
      - "INSERT (:Node:Special {name: 'C'})"
    query: MATCH (n) WHERE n:Special RETURN n.name AS name
    expect:
      rows:
        - [C]

  - name: where_label_predicate_multi
    setup:
      - "INSERT (:Node {name: 'A'})"
      - "INSERT (:Node:Special {name: 'B'})"
    query: MATCH (n) WHERE n:Node:Special RETURN n.name AS name
    expect:
      rows:
        - [B]

  - name: where_label_predicate_with_and
    setup:
      - "INSERT (:Node {name: 'A'})"
      - "INSERT (:Node {name: 'B'})"
    query: "MATCH (n) WHERE n:Node AND n.name = 'A' RETURN n.name AS name"
    expect:
      rows:
        - [A]

  # ---------------------------------------------------------------------------
  # Undirected edges
  # ---------------------------------------------------------------------------

  - name: undirected_edge_match
    setup:
      - "INSERT (:Node {name: 'A'})"
      - "INSERT (:Node {name: 'B'})"
      - "INSERT (:Node {name: 'C'})"
      - "MATCH (a:Node {name: 'A'}), (b:Node {name: 'B'}) INSERT (a)-[:LINK]->(b)"
      - "MATCH (c:Node {name: 'C'}), (b:Node {name: 'B'}) INSERT (c)-[:LINK]->(b)"
    query: "MATCH (a:Node {name: 'B'})-[:LINK]-(b:Node) RETURN b.name AS name ORDER BY name"
    expect:
      ordered: true
      rows:
        - [A]
        - [C]

  # ---------------------------------------------------------------------------
  # Edge property filters in WHERE
  # ---------------------------------------------------------------------------

  - name: edge_property_filter_where
    setup:
      - "INSERT (:Person {name: 'Alix'})"
      - "INSERT (:Person {name: 'Gus'})"
      - "INSERT (:Person {name: 'Vincent'})"
      - "MATCH (a:Person {name: 'Alix'}), (b:Person {name: 'Gus'}) INSERT (a)-[:RATED {stars: 5}]->(b)"
      - "MATCH (a:Person {name: 'Alix'}), (v:Person {name: 'Vincent'}) INSERT (a)-[:RATED {stars: 2}]->(v)"
    query: "MATCH (a:Person)-[r:RATED]->(b:Person) WHERE r.stars >= 4 RETURN b.name AS name"
    expect:
      rows:
        - [Gus]

  # ---------------------------------------------------------------------------
  # Path length
  # ---------------------------------------------------------------------------

  - name: path_length_four_hops
    setup:
      - "INSERT (:Node {name: 'A'})"
      - "INSERT (:Node {name: 'B'})"
      - "INSERT (:Node {name: 'C'})"
      - "INSERT (:Node {name: 'D'})"
      - "INSERT (:Node {name: 'E'})"
      - "MATCH (a:Node {name: 'A'}), (b:Node {name: 'B'}) INSERT (a)-[:LINK]->(b)"
      - "MATCH (b:Node {name: 'B'}), (c:Node {name: 'C'}) INSERT (b)-[:LINK]->(c)"
      - "MATCH (c:Node {name: 'C'}), (d:Node {name: 'D'}) INSERT (c)-[:LINK]->(d)"
      - "MATCH (d:Node {name: 'D'}), (e:Node {name: 'E'}) INSERT (d)-[:LINK]->(e)"
    query: "MATCH p = (a:Node {name: 'A'})-[:LINK *1..4]->(b:Node {name: 'E'}) RETURN length(p) AS len"
    expect:
      rows:
        - [4]

  # ---------------------------------------------------------------------------
  # Wildcard edge type
  # ---------------------------------------------------------------------------

  - name: wildcard_edge_any_type
    setup:
      - "INSERT (:Node {name: 'A'})"
      - "INSERT (:Node {name: 'B'})"
      - "INSERT (:Node {name: 'C'})"
      - "MATCH (a:Node {name: 'A'}), (b:Node {name: 'B'}) INSERT (a)-[:LINK]->(b)"
      - "MATCH (a:Node {name: 'A'}), (c:Node {name: 'C'}) INSERT (a)-[:SHORTCUT]->(c)"
    query: "MATCH (a:Node {name: 'A'})-[]->(b:Node) RETURN b.name AS name ORDER BY name"
    expect:
      ordered: true
      rows:
        - [B]
        - [C]

  # ---------------------------------------------------------------------------
  # Path with intermediate filter
  # ---------------------------------------------------------------------------

  - name: path_with_intermediate_filter
    setup:
      - "INSERT (:Node {name: 'A'})"
      - "INSERT (:Node {name: 'B'})"
      - "INSERT (:Node {name: 'C'})"
      - "INSERT (:Node {name: 'X'})"
      - "MATCH (a:Node {name: 'A'}), (b:Node {name: 'B'}) INSERT (a)-[:LINK]->(b)"
      - "MATCH (b:Node {name: 'B'}), (c:Node {name: 'C'}) INSERT (b)-[:LINK]->(c)"
      - "MATCH (a:Node {name: 'A'}), (x:Node {name: 'X'}) INSERT (a)-[:LINK]->(x)"
      - "MATCH (x:Node {name: 'X'}), (c:Node {name: 'C'}) INSERT (x)-[:LINK]->(c)"
    query: "MATCH (a:Node {name: 'A'})-[:LINK]->(mid:Node)-[:LINK]->(c:Node) WHERE mid.name = 'B' RETURN c.name AS name"
    expect:
      rows:
        - [C]
