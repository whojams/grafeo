{
  "name": "@grafeo-db/js",
  "version": "0.5.35",
  "description": "Node.js/TypeScript bindings for Grafeo - a high-performance embeddable graph database",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "grafeo",
    "targets": [
      "x86_64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "optionalDependencies": {
    "@grafeo-db/js-darwin-x64": "0.5.35",
    "@grafeo-db/js-win32-x64-msvc": "0.5.35",
    "@grafeo-db/js-linux-x64-gnu": "0.5.35",
    "@grafeo-db/js-darwin-arm64": "0.5.35",
    "@grafeo-db/js-linux-arm64-gnu": "0.5.35",
    "@grafeo-db/js-linux-arm64-musl": "0.5.35"
  },
  "keywords": [
    "graph",
    "database",
    "gql",
    "cypher",
    "sparql",
    "knowledge-graph",
    "native",
    "napi",
    "embedded"
  ],
  "author": "S.T. Grond",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/GrafeoDB/grafeo.git",
    "directory": "crates/bindings/node"
  },
  "homepage": "https://grafeo.dev",
  "bugs": {
    "url": "https://github.com/GrafeoDB/grafeo/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release --features full",
    "build:debug": "napi build --platform",
    "test": "vitest run",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "vitest": "^4.0.18"
  }
}
