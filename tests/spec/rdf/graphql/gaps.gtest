# GraphQL implementation gaps on RDF-like data
#
# Documents known RDF-specific limitations in the GraphQL translator.
# All tests are skipped with reason strings explaining the gap.

meta:
  language: graphql
  model: rdf
  section: gaps
  title: Known GraphQL gaps on RDF data
  dataset: rdf_social
  requires: [graphql]

tests:

  # ---------------------------------------------------------------------------
  # Variable substitution ($variable not wired)
  # ---------------------------------------------------------------------------

  - name: variable_substitution_string
    query: |
      query GetPerson($personName: String!) {
        person(name: $personName) { name age }
      }
    params:
      personName: "Alix"
    expect:
      rows:
        - [Alix, 30]

  - name: variable_substitution_int
    query: |
      query GetByAge($minAge: Int!) {
        person(age_gte: $minAge) { name age }
      }
    params:
      minAge: 30
    expect:
      count: 3

  # ---------------------------------------------------------------------------
  # Directive execution (@skip / @include)
  # ---------------------------------------------------------------------------

  - name: directive_skip_true
    query: "{ person { name age @skip(if: true) } }"
    expect:
      columns: [name]
      count: 5

  - name: directive_include_false
    query: "{ person { name age @include(if: false) } }"
    expect:
      columns: [name]
      count: 5

  - name: directive_include_true
    query: "{ person { name age @include(if: true) } }"
    expect:
      count: 5

  # ---------------------------------------------------------------------------
  # Multiple root fields (only first root field processed)
  # ---------------------------------------------------------------------------

  - name: multiple_root_fields
    query: |
      query {
        person { name }
        organization { name }
      }
    expect:
      # Should return rows for both Person and Organization types
      count: 6

  # ---------------------------------------------------------------------------
  # Aggregation (no count/sum/avg support)
  # ---------------------------------------------------------------------------

  - name: aggregation_count
    skip: "Aggregation functions not supported in GraphQL translator"
    query: "{ personCount: person { _count } }"
    expect:
      rows:
        - [5]

  - name: aggregation_avg_age
    skip: "Aggregation functions not supported in GraphQL translator"
    query: "{ person { _avg(field: age) } }"
    expect:
      rows:
        - [30]

  - name: aggregation_sum_age
    skip: "Aggregation functions not supported in GraphQL translator"
    query: "{ person { _sum(field: age) } }"
    expect:
      rows:
        - [150]

  # ---------------------------------------------------------------------------
  # Deep nesting (4+ levels)
  # ---------------------------------------------------------------------------

  - name: deeply_nested_four_levels
    skip: "Deep nesting (4+ levels) fails with column resolution error"
    query: |
      query {
        person(name: "Alix") {
          name
          knows {
            name
            knows {
              name
              knows {
                name
              }
            }
          }
        }
      }
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # Variable with default value
  # ---------------------------------------------------------------------------

  - name: variable_with_default_value
    skip: "RDF GraphQL translator does not support pagination (first/limit arguments)"
    query: "query($limit: Int = 2) { person(first: $limit) { name } }"
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # Multiple root fields combined (inline, not separate operations)
  # ---------------------------------------------------------------------------

  - name: multiple_root_fields_combined
    query: "{ person(name: \"Alix\") { name } organization { name } }"
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # RDF mutation rejection (test harness routes through LPG translator)
  # ---------------------------------------------------------------------------

  - name: rdf_create_mutation_rejected
    skip: "Test harness uses LPG translator which accepts mutations; RDF translator rejects them"
    query: "mutation { createPerson(name: \"Test\") { name } }"
    expect:
      error: "Only Query"

  - name: rdf_delete_mutation_rejected
    skip: "Test harness uses LPG translator which accepts mutations; RDF translator rejects them"
    query: "mutation { deletePerson(name: \"Alix\") }"
    expect:
      error: "Only Query"
