# GQL Subqueries: ISO/IEC 39075:2024 sec 18.1

meta:
  language: gql
  model: lpg
  section: "18.1"
  title: Subqueries
  dataset: empty

tests:

  - name: exists_basic
    setup:
      - "INSERT (:Person {name: 'Alix'})-[:KNOWS]->(:Person {name: 'Gus'})"
      - "INSERT (:Person {name: 'Vincent'})"
    query: "MATCH (p:Person) WHERE EXISTS { MATCH (p)-[:KNOWS]->() } RETURN p.name"
    expect:
      rows:
        - [Alix]

  - name: not_exists_subquery
    setup:
      - "INSERT (:Person {name: 'Alix'})-[:KNOWS]->(:Person {name: 'Gus'})"
    query: "MATCH (p:Person) WHERE NOT EXISTS { MATCH (p)-[:KNOWS]->() } RETURN p.name"
    expect:
      rows:
        - [Gus]

  - name: exists_correlated_variable
    setup:
      - "INSERT (:Person {name: 'Alix', city: 'Amsterdam'})"
      - "INSERT (:Person {name: 'Gus', city: 'Berlin'})"
      - "INSERT (:City {name: 'Amsterdam'})"
    query: |
      MATCH (p:Person)
      WHERE EXISTS {
        MATCH (c:City) WHERE c.name = p.city
      }
      RETURN p.name
    expect:
      rows:
        - [Alix]

  - name: count_subquery_in_return
    setup:
      - "INSERT (:Person {name: 'Alix'})-[:KNOWS]->(:Person {name: 'Gus'})"
      - "MATCH (a:Person {name: 'Alix'}) INSERT (a)-[:KNOWS]->(:Person {name: 'Vincent'})"
    query: |
      MATCH (p:Person {name: 'Alix'})
      RETURN p.name, COUNT { MATCH (p)-[:KNOWS]->() } AS friend_count
    expect:
      rows:
        - [Alix, 2]

  - name: call_subquery_aggregation
    setup:
      - "INSERT (:Person {name: 'Alix'})"
      - "INSERT (:Person {name: 'Gus'})"
      - "INSERT (:Person {name: 'Vincent'})"
    query: "CALL { MATCH (n:Person) RETURN count(n) AS total } RETURN total"
    expect:
      rows:
        - [3]

  - name: sibling_call_same_variable_name
    description: >
      Same-named variables in sibling CALL blocks must not collide.
      Each block's internal 'n' is independent; only the aliased outputs
      should be visible to the outer RETURN.
    setup:
      - "INSERT (:Person {name: 'Alix'})"
      - "INSERT (:Company {name: 'TechCorp'})"
    query: |
      CALL { MATCH (n:Person) RETURN n.name AS person_name }
      CALL { MATCH (n:Company) RETURN n.name AS company_name }
      RETURN person_name, company_name
    expect:
      rows:
        - [Alix, TechCorp]

  - name: sibling_call_outputs_both_visible
    description: >
      Two sibling CALL blocks with different variables should both produce
      their aliased outputs in the outer RETURN.
    setup:
      - "INSERT (:Person {name: 'Alix', age: 30})"
      - "INSERT (:Person {name: 'Gus', age: 25})"
    query: |
      CALL { MATCH (a:Person {name: 'Alix'}) RETURN a.age AS age_a }
      CALL { MATCH (b:Person {name: 'Gus'}) RETURN b.age AS age_b }
      RETURN age_a, age_b
    expect:
      rows:
        - [30, 25]

  - name: three_sibling_calls_same_variable
    description: >
      Three sibling CALL blocks all using 'n' internally should each
      resolve independently.
    setup:
      - "INSERT (:Person {name: 'Alix'})"
      - "INSERT (:Company {name: 'TechCorp'})"
      - "INSERT (:City {name: 'Amsterdam'})"
    query: |
      CALL { MATCH (n:Person) RETURN n.name AS pname }
      CALL { MATCH (n:Company) RETURN n.name AS cname }
      CALL { MATCH (n:City) RETURN n.name AS city }
      RETURN pname, cname, city
    expect:
      rows:
        - [Alix, TechCorp, Amsterdam]
