# GQL List Operations: ISO/IEC 39075:2024 sec 16.3
#
# Covers: list predicates (all, any, none, single), list comprehension,
# list index access, list slicing, IN predicate, size/cardinality,
# head, last, tail, range.

meta:
  language: gql
  model: lpg
  section: "16.3"
  title: List operations
  dataset: empty

tests:

  # ---------------------------------------------------------------------------
  # List predicates: all, any, none, single
  # ---------------------------------------------------------------------------

  - name: all_predicate_true
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN all(x IN [2, 4, 6] WHERE x % 2 = 0) AS result"
    expect:
      rows:
        - [true]

  - name: all_predicate_false
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN all(x IN [1, 2, 3] WHERE x > 1) AS result"
    expect:
      rows:
        - [false]

  - name: any_predicate_true
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN any(x IN [1, 2, 3] WHERE x > 2) AS result"
    expect:
      rows:
        - [true]

  - name: any_predicate_false
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN any(x IN [1, 2, 3] WHERE x > 10) AS result"
    expect:
      rows:
        - [false]

  - name: none_predicate_true
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN none(x IN [1, 2, 3] WHERE x > 10) AS result"
    expect:
      rows:
        - [true]

  - name: none_predicate_false
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN none(x IN [1, 2, 3] WHERE x > 2) AS result"
    expect:
      rows:
        - [false]

  - name: single_predicate_true
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN single(x IN [1, 2, 3] WHERE x = 2) AS result"
    expect:
      rows:
        - [true]

  - name: single_predicate_false
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN single(x IN [1, 2, 3] WHERE x > 1) AS result"
    expect:
      rows:
        - [false]

  # ---------------------------------------------------------------------------
  # List predicates in WHERE clause
  # ---------------------------------------------------------------------------

  - name: all_predicate_in_where
    setup:
      - "INSERT (:Flag {v: 1})"
    query: "MATCH (f:Flag) WHERE all(x IN [2, 4, 6] WHERE x % 2 = 0) RETURN f.v AS v"
    expect:
      rows:
        - [1]

  - name: any_predicate_in_where
    setup:
      - "INSERT (:Flag {v: 1})"
    query: "MATCH (f:Flag) WHERE any(x IN [1, 2, 3] WHERE x > 2) RETURN f.v AS v"
    expect:
      rows:
        - [1]

  # ---------------------------------------------------------------------------
  # List comprehension
  # ---------------------------------------------------------------------------

  - name: list_comprehension_filter_and_transform
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN [x IN [1, 2, 3, 4, 5] WHERE x > 2 | x * 10] AS filtered"
    expect:
      rows:
        - ["[30, 40, 50]"]

  - name: list_comprehension_filter_only
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN [x IN [1, 2, 3, 4, 5] WHERE x > 3] AS filtered"
    expect:
      rows:
        - ["[4, 5]"]

  - name: list_comprehension_transform_only
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN [x IN [1, 2, 3] | x * 2] AS doubled"
    expect:
      rows:
        - ["[2, 4, 6]"]

  # ---------------------------------------------------------------------------
  # List index access
  # ---------------------------------------------------------------------------

  - name: list_index_first
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN [10, 20, 30][0] AS first"
    expect:
      rows:
        - [10]

  - name: list_index_second
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN [10, 20, 30][1] AS second"
    expect:
      rows:
        - [20]

  - name: list_index_negative
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN [10, 20, 30][-1] AS last_elem"
    expect:
      rows:
        - [30]

  - name: list_index_negative_second
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN [10, 20, 30][-2] AS second_from_end"
    expect:
      rows:
        - [20]

  # ---------------------------------------------------------------------------
  # List slicing
  # ---------------------------------------------------------------------------

  - name: list_slice_start_end
    skip: "GQL parser does not support [start..end] slice syntax"
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN [10, 20, 30, 40, 50][1..3] AS sliced"
    expect:
      rows:
        - ["[20, 30]"]

  - name: list_slice_from_start
    skip: "GQL parser does not support [..end] slice syntax"
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN [10, 20, 30, 40, 50][..2] AS sliced"
    expect:
      rows:
        - ["[10, 20]"]

  - name: list_slice_to_end
    skip: "GQL parser does not support [start..] slice syntax"
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN [10, 20, 30, 40, 50][3..] AS sliced"
    expect:
      rows:
        - ["[40, 50]"]

  # ---------------------------------------------------------------------------
  # IN predicate with list
  # ---------------------------------------------------------------------------

  - name: in_predicate_match
    setup:
      - "INSERT (:N {name: 'Alix'})"
      - "INSERT (:N {name: 'Gus'})"
      - "INSERT (:N {name: 'Vincent'})"
    query: "MATCH (n:N) WHERE n.name IN ['Alix', 'Gus'] RETURN n.name AS name ORDER BY name"
    expect:
      ordered: true
      rows:
        - [Alix]
        - [Gus]

  - name: in_predicate_no_match
    setup:
      - "INSERT (:N {name: 'Alix'})"
    query: "MATCH (n:N) WHERE n.name IN ['Django', 'Beatrix'] RETURN n.name"
    expect:
      empty: true

  - name: in_predicate_empty_list
    setup:
      - "INSERT (:N {name: 'Alix'})"
    query: "MATCH (n:N) WHERE n.name IN [] RETURN n.name"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # size / cardinality
  # ---------------------------------------------------------------------------

  - name: size_of_list
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN size([10, 20, 30]) AS s"
    expect:
      rows:
        - [3]

  - name: cardinality_of_list
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN cardinality([1, 2, 3, 4, 5]) AS c"
    expect:
      rows:
        - [5]

  - name: cardinality_empty_list
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN cardinality([]) AS c"
    expect:
      rows:
        - [0]

  - name: size_of_string
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN size('hello') AS s"
    expect:
      rows:
        - [5]

  # ---------------------------------------------------------------------------
  # head, last, tail
  # ---------------------------------------------------------------------------

  - name: head_of_list
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN head([10, 20, 30]) AS h"
    expect:
      rows:
        - [10]

  - name: last_of_list
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN last([10, 20, 30]) AS l"
    expect:
      rows:
        - [30]

  - name: tail_of_list
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN tail([10, 20, 30]) AS t"
    expect:
      rows:
        - ["[20, 30]"]

  - name: head_of_empty_list
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN head([]) AS h"
    expect:
      rows:
        - [null]

  - name: last_of_empty_list
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN last([]) AS l"
    expect:
      rows:
        - [null]

  - name: tail_of_empty_list
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN tail([]) AS t"
    expect:
      rows:
        - ["[]"]

  # ---------------------------------------------------------------------------
  # range function
  # ---------------------------------------------------------------------------

  - name: range_two_args
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN range(1, 5) AS r"
    expect:
      rows:
        - ["[1, 2, 3, 4, 5]"]

  - name: range_with_step
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN range(0, 10, 3) AS r"
    expect:
      rows:
        - ["[0, 3, 6, 9]"]

  - name: range_single_element
    setup:
      - "INSERT (:N {v: 1})"
    query: "MATCH (n:N) RETURN range(5, 5) AS r"
    expect:
      rows:
        - ["[5]"]
