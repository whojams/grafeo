# GraphQL query support for Grafeo LPG
#
# Covers: type-based node queries, field selection, named and shorthand syntax,
# field aliases, direct argument equality filters, range filters (_gt, _gte,
# _lt, _lte, _ne), string operators (_contains, _starts_with, _ends_with),
# compound filters, where/filter object syntax, _in operator, pagination
# (first, skip, limit, offset), ordering (orderBy), nested relationship
# traversals, and empty result cases.

meta:
  language: graphql
  model: lpg
  title: GraphQL queries
  dataset: social_network

tests:

  # ---------------------------------------------------------------------------
  # 1. Basic node queries by type
  # ---------------------------------------------------------------------------

  - name: query_all_persons
    query: "query { person { name } }"
    expect:
      count: 3

  - name: query_all_persons_with_values
    query: "query { person { name } }"
    expect:
      rows:
        - [Alix]
        - [Gus]
        - [Vincent]

  - name: query_all_companies
    query: "query { company { name } }"
    expect:
      rows:
        - [Grafeo OSS]

  - name: query_person_multiple_fields
    query: "query { person { name age city } }"
    expect:
      rows:
        - [Alix, 30, Amsterdam]
        - [Gus, 25, Berlin]
        - [Vincent, 35, Paris]

  - name: query_company_multiple_fields
    query: "query { company { name founded } }"
    expect:
      rows:
        - [Grafeo OSS, 2025]

  - name: query_nonexistent_type
    query: "query { animal { name } }"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # 2. Named and shorthand queries
  # ---------------------------------------------------------------------------

  - name: named_query_with_keyword
    query: "query GetPeople { person { name } }"
    expect:
      count: 3

  - name: shorthand_query_no_keyword
    query: "{ person { name } }"
    expect:
      count: 3

  - name: shorthand_with_filter
    query: "{ person(name: \"Alix\") { name age } }"
    expect:
      rows:
        - [Alix, 30]

  - name: named_query_with_filter
    query: "query FindGus { person(name: \"Gus\") { name city } }"
    expect:
      rows:
        - [Gus, Berlin]

  # ---------------------------------------------------------------------------
  # 3. Field aliases
  # ---------------------------------------------------------------------------

  - name: alias_single_field
    query: "{ person(name: \"Alix\") { userName: name } }"
    expect:
      columns: [userName]
      rows:
        - [Alix]

  - name: alias_multiple_fields
    query: "{ person(name: \"Vincent\") { personName: name personAge: age } }"
    expect:
      columns: [personName, personAge]
      rows:
        - [Vincent, 35]

  # ---------------------------------------------------------------------------
  # 4. Direct argument equality filters
  # ---------------------------------------------------------------------------

  - name: filter_by_name
    query: "{ person(name: \"Alix\") { name age } }"
    expect:
      rows:
        - [Alix, 30]

  - name: filter_by_age
    query: "{ person(age: 25) { name } }"
    expect:
      rows:
        - [Gus]

  - name: filter_by_city
    query: "{ person(city: \"Amsterdam\") { name } }"
    expect:
      rows:
        - [Alix]

  - name: filter_by_multiple_args
    query: "{ person(name: \"Alix\", age: 30) { name city } }"
    expect:
      rows:
        - [Alix, Amsterdam]

  - name: filter_no_match
    query: "{ person(name: \"Django\") { name } }"
    expect:
      empty: true

  - name: filter_company_by_name
    query: "{ company(name: \"Grafeo OSS\") { name founded } }"
    expect:
      rows:
        - [Grafeo OSS, 2025]

  - name: filter_company_no_match
    query: "{ company(name: \"Acme\") { name } }"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # 5. Direct argument range filters (_gt, _gte, _lt, _lte, _ne)
  # ---------------------------------------------------------------------------

  - name: filter_age_gt
    query: "{ person(age_gt: 28) { name } }"
    expect:
      rows:
        - [Alix]
        - [Vincent]

  - name: filter_age_gte
    query: "{ person(age_gte: 30) { name } }"
    expect:
      rows:
        - [Alix]
        - [Vincent]

  - name: filter_age_lt
    query: "{ person(age_lt: 30) { name } }"
    expect:
      rows:
        - [Gus]

  - name: filter_age_lte
    query: "{ person(age_lte: 30) { name } }"
    expect:
      rows:
        - [Alix]
        - [Gus]

  - name: filter_age_ne
    query: "{ person(age_ne: 30) { name } }"
    expect:
      rows:
        - [Gus]
        - [Vincent]

  - name: filter_founded_gt
    query: "{ company(founded_gt: 2020) { name } }"
    expect:
      rows:
        - [Grafeo OSS]

  - name: filter_founded_lt_no_match
    query: "{ company(founded_lt: 2000) { name } }"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # 6. Direct argument string operators (_contains, _starts_with, _ends_with)
  # ---------------------------------------------------------------------------

  - name: filter_name_contains
    query: "{ person(name_contains: \"li\") { name } }"
    expect:
      rows:
        - [Alix]

  - name: filter_name_starts_with
    query: "{ person(name_starts_with: \"Vi\") { name } }"
    expect:
      rows:
        - [Vincent]

  - name: filter_name_ends_with
    query: "{ person(name_ends_with: \"us\") { name } }"
    expect:
      rows:
        - [Gus]

  - name: filter_city_contains
    query: "{ person(city_contains: \"er\") { name } }"
    expect:
      rows:
        - [Alix]
        - [Gus]

  - name: filter_city_starts_with
    query: "{ person(city_starts_with: \"Am\") { name } }"
    expect:
      rows:
        - [Alix]

  - name: filter_city_ends_with
    query: "{ person(city_ends_with: \"is\") { name } }"
    expect:
      rows:
        - [Vincent]

  - name: filter_name_contains_no_match
    query: "{ person(name_contains: \"xyz\") { name } }"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # 7. Compound range filters
  # ---------------------------------------------------------------------------

  - name: compound_age_range
    query: "{ person(age_gt: 20, age_lt: 35) { name } }"
    expect:
      rows:
        - [Alix]
        - [Gus]

  - name: compound_age_range_inclusive
    query: "{ person(age_gte: 25, age_lte: 30) { name } }"
    expect:
      rows:
        - [Alix]
        - [Gus]

  - name: compound_city_and_age_gt
    query: "{ person(city: \"Amsterdam\", age_gt: 25) { name } }"
    expect:
      rows:
        - [Alix]

  - name: compound_three_filters
    query: "{ person(age_gte: 25, age_lte: 35, city: \"Berlin\") { name } }"
    expect:
      rows:
        - [Gus]

  - name: compound_range_no_match
    query: "{ person(age_gt: 36, age_lt: 40) { name } }"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # 8. Where/filter object syntax
  # ---------------------------------------------------------------------------

  - name: where_object_equality
    query: "query { person(where: { name: \"Alix\" }) { name age } }"
    expect:
      rows:
        - [Alix, 30]

  - name: where_object_age_gt
    query: "query { person(where: { age_gt: 28 }) { name } }"
    expect:
      rows:
        - [Alix]
        - [Vincent]

  - name: where_object_age_lt
    query: "query { person(where: { age_lt: 30 }) { name } }"
    expect:
      rows:
        - [Gus]

  - name: where_object_compound
    query: "query { person(where: { age_gte: 25, city: \"Berlin\" }) { name } }"
    expect:
      rows:
        - [Gus]

  - name: filter_object_equality
    query: "query { person(filter: { name: \"Vincent\" }) { name age } }"
    expect:
      rows:
        - [Vincent, 35]

  - name: filter_object_age_gt
    query: "query { person(filter: { age_gt: 28 }) { name } }"
    expect:
      rows:
        - [Alix]
        - [Vincent]

  - name: filter_object_name_contains
    query: "query { person(filter: { name_contains: \"in\" }) { name } }"
    expect:
      rows:
        - [Vincent]

  - name: filter_object_city_starts_with
    query: "query { person(filter: { city_starts_with: \"Pa\" }) { name } }"
    expect:
      rows:
        - [Vincent]

  # ---------------------------------------------------------------------------
  # 9. Where with _in operator
  # ---------------------------------------------------------------------------

  - name: filter_age_in
    query: "{ person(age_in: [25, 35]) { name } }"
    expect:
      rows:
        - [Gus]
        - [Vincent]

  - name: filter_city_in
    query: "{ person(city_in: [\"Amsterdam\", \"Paris\"]) { name } }"
    expect:
      rows:
        - [Alix]
        - [Vincent]

  - name: where_object_age_in
    query: "query { person(where: { age_in: [25, 30] }) { name } }"
    expect:
      rows:
        - [Alix]
        - [Gus]

  - name: filter_city_in_single
    query: "{ person(city_in: [\"Berlin\"]) { name } }"
    expect:
      rows:
        - [Gus]

  - name: filter_age_in_no_match
    query: "{ person(age_in: [99, 100]) { name } }"
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # 10. Pagination (first, skip, limit, offset)
  # ---------------------------------------------------------------------------

  - name: first_limits_results
    query: "{ person(first: 2) { name } }"
    expect:
      count: 2

  - name: first_one_result
    query: "{ person(first: 1) { name } }"
    expect:
      count: 1

  - name: limit_alias_for_first
    query: "{ person(limit: 2) { name } }"
    expect:
      count: 2

  - name: skip_offsets_results
    query: "{ person(first: 2, skip: 1) { name } }"
    expect:
      count: 2

  - name: offset_alias_for_skip
    query: "{ person(limit: 2, offset: 1) { name } }"
    expect:
      count: 2

  - name: skip_all
    query: "{ person(skip: 3) { name } }"
    expect:
      empty: true

  - name: first_exceeds_total
    query: "{ person(first: 100) { name } }"
    expect:
      count: 3

  - name: skip_and_first_combined
    query: "{ person(skip: 1, first: 1) { name } }"
    expect:
      count: 1

  # ---------------------------------------------------------------------------
  # 11. Ordering (orderBy)
  # ---------------------------------------------------------------------------

  - name: order_by_name_asc
    query: |
      query {
        person(orderBy: { name: ASC }) {
          name
        }
      }
    expect:
      ordered: true
      rows:
        - [Alix]
        - [Gus]
        - [Vincent]

  - name: order_by_name_desc
    query: |
      query {
        person(orderBy: { name: DESC }) {
          name
        }
      }
    expect:
      ordered: true
      rows:
        - [Vincent]
        - [Gus]
        - [Alix]

  - name: order_by_age_asc
    query: |
      query {
        person(orderBy: { age: ASC }) {
          name
          age
        }
      }
    expect:
      ordered: true
      rows:
        - [Gus, 25]
        - [Alix, 30]
        - [Vincent, 35]

  - name: order_by_age_desc
    query: |
      query {
        person(orderBy: { age: DESC }) {
          name
          age
        }
      }
    expect:
      ordered: true
      rows:
        - [Vincent, 35]
        - [Alix, 30]
        - [Gus, 25]

  - name: order_by_age_asc_with_first
    query: |
      query {
        person(orderBy: { age: ASC }, first: 2) {
          name
          age
        }
      }
    expect:
      ordered: true
      rows:
        - [Gus, 25]
        - [Alix, 30]

  - name: order_by_age_desc_with_first
    query: |
      query {
        person(orderBy: { age: DESC }, first: 1) {
          name
          age
        }
      }
    expect:
      ordered: true
      rows:
        - [Vincent, 35]

  - name: order_by_with_skip_and_first
    query: |
      query {
        person(orderBy: { age: ASC }, skip: 1, first: 1) {
          name
          age
        }
      }
    expect:
      ordered: true
      rows:
        - [Alix, 30]

  - name: order_by_with_skip
    query: |
      query {
        person(orderBy: { age: ASC }, skip: 2) {
          name
          age
        }
      }
    expect:
      ordered: true
      rows:
        - [Vincent, 35]

  # ---------------------------------------------------------------------------
  # 12. Nested relationship traversals
  # ---------------------------------------------------------------------------

  - name: nested_knows_traversal
    # Alix->Gus and Gus->Vincent, so 2 rows with outgoing KNOWS
    query: "query { person { name knows { name } } }"
    expect:
      count: 2

  - name: nested_knows_with_parent_filter
    query: |
      query {
        person(name: "Alix") {
          name
          knows {
            name
          }
        }
      }
    expect:
      rows:
        - [Alix, Gus]

  - name: nested_knows_from_gus
    query: |
      query {
        person(name: "Gus") {
          name
          knows {
            name
          }
        }
      }
    expect:
      rows:
        - [Gus, Vincent]

  - name: nested_works_at_traversal
    query: |
      query {
        person(name: "Alix") {
          name
          works_at {
            name
          }
        }
      }
    expect:
      rows:
        - [Alix, Grafeo OSS]

  - name: nested_knows_with_filter_on_target
    query: |
      query {
        person(name: "Alix") {
          name
          knows(age: 25) {
            name
            age
          }
        }
      }
    expect:
      count: 1

  - name: nested_knows_with_age_gt_on_target
    query: |
      query {
        person(name: "Gus") {
          name
          knows(age_gt: 30) {
            name
            age
          }
        }
      }
    expect:
      count: 1

  - name: nested_no_outgoing_relationships
    # Vincent has no outgoing KNOWS edges
    query: |
      query {
        person(name: "Vincent") {
          name
          knows {
            name
          }
        }
      }
    expect:
      empty: true

  - name: nested_works_at_no_match
    # Gus has no WORKS_AT edges
    query: |
      query {
        person(name: "Gus") {
          name
          works_at {
            name
          }
        }
      }
    expect:
      empty: true

  # ---------------------------------------------------------------------------
  # 13. Empty results (nonexistent label, no match filter)
  # ---------------------------------------------------------------------------

  - name: empty_nonexistent_label
    query: "{ robot { name } }"
    expect:
      empty: true

  - name: empty_filter_no_match_age
    query: "{ person(age: 99) { name } }"
    expect:
      empty: true

  - name: empty_filter_no_match_city
    query: "{ person(city: \"Tokyo\") { name } }"
    expect:
      empty: true

  - name: empty_compound_filter_contradictory
    query: "{ person(age_gt: 40, age_lt: 20) { name } }"
    expect:
      empty: true

  - name: empty_string_filter_no_match
    query: "{ person(name_starts_with: \"Zz\") { name } }"
    expect:
      empty: true
